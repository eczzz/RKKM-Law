# Netlify cache-control headers — applied to the matching paths after deploy.
# Netlify also auto-enables gzip + brotli for all served content; nothing
# extra needed for compression.

# Astro build output — filenames are content-hashed, safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images — change rarely; 30-day cache. Update filename to bust.
/images/*
  Cache-Control: public, max-age=2592000

/badges/*
  Cache-Control: public, max-age=2592000

# Favicons
/favicon.svg
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=2592000

# Logos referenced from the public root
/Main-Logo-KM-Law.webp
  Cache-Control: public, max-age=2592000

# robots and sitemap — short cache so updates propagate quickly
/robots.txt
  Cache-Control: public, max-age=3600

/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-0.xml
  Cache-Control: public, max-age=3600
