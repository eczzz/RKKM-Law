---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientHero from '../components/client/ClientHero.astro';
import ClientResources from '../components/client/ClientResources.astro';
import ClientLearnMore from '../components/client/ClientLearnMore.astro';

const description =
  'Client portal for Kukreja McFarlane Law — share documents, pay invoices, and access firm resources. For current clients only.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: 'https://www.rkkmlaw.com/client-page',
  name: 'Client Page — KM Law',
  description,
  isPartOf: { '@id': 'https://www.rkkmlaw.com/#organization' },
  audience: {
    '@type': 'Audience',
    audienceType: 'Current clients of Kukreja McFarlane Law',
  },
};
---

<BaseLayout title="Client Page — KM Law" description={description} headerTheme="dark" schema={schema}>
  <ClientHero />
  <ClientResources />
  <ClientLearnMore />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .cr__eyebrow[data-anim],
  .cl__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
