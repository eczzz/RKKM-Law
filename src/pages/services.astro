---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicesHero from '../components/services/ServicesHero.astro';
import ServicesPracticeAreas from '../components/services/ServicesPracticeAreas.astro';
import ServicesCTA from '../components/services/ServicesCTA.astro';

const description =
  'High-asset divorce, complex custody, spousal support, and mediation — KM Law\'s family law practice areas, handled by trial-experienced Colorado attorneys.';

// LegalService with offerCatalog of practice areas. provider references the
// canonical firm record defined on the home page.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  url: 'https://www.rkkmlaw.com/services',
  name: 'KM Law — Practice Areas',
  description,
  provider: { '@id': 'https://www.rkkmlaw.com/#organization' },
  areaServed: { '@type': 'State', name: 'Colorado' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Family Law Practice Areas',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'High-Asset Divorce',
          url: 'https://www.rkkmlaw.com/services#high-asset-divorce',
          serviceType: 'Family Law',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Child Custody & Parenting',
          url: 'https://www.rkkmlaw.com/services#child-custody',
          serviceType: 'Family Law',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Spousal Support & Maintenance',
          url: 'https://www.rkkmlaw.com/services#spousal-support',
          serviceType: 'Family Law',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Mediation & Alternative Dispute Resolution',
          url: 'https://www.rkkmlaw.com/services#mediation',
          serviceType: 'Family Law',
        },
      },
    ],
  },
};
---

<BaseLayout title="Services — KM Law" description={description} headerTheme="dark" schema={schema}>
  <ServicesHero />
  <ServicesPracticeAreas />
  <ServicesCTA />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .sh__eyebrow[data-anim],
  .sr__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ---- Header overrides: light text on navy hero (before scroll) ----
     .header prefix bumps specificity to (0,4,0) to beat Astro-scoped
     Header.astro dark-theme rules which compile with [data-astro-cid]. ---- */
  .header.header--dark:not(.header--scrolled) .header__nav-link {
    color: rgba(250, 250, 249, 0.55);
  }

  .header.header--dark:not(.header--scrolled) .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__nav-link::after {
    background: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__cta {
    color: #FAFAF9;
    border-bottom-color: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__cta:hover {
    color: rgba(250, 250, 249, 0.7);
  }

  .header.header--dark:not(.header--scrolled) .header__cta-arrow {
    color: #FAFAF9;
  }

  @media (max-width: 768px) {
    .header--dark:not(.header--scrolled) .header__hamburger-wrap path {
      stroke: #FAFAF9;
    }
  }
</style>
