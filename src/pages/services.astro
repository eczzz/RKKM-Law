---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicesHero from '../components/services/ServicesHero.astro';
import ServicesPracticeAreas from '../components/services/ServicesPracticeAreas.astro';
import ServicesCTA from '../components/services/ServicesCTA.astro';
---

<BaseLayout title="Services — KM Law" headerTheme="dark">
  <ServicesHero />
  <ServicesPracticeAreas />
  <ServicesCTA />
</BaseLayout>

<style is:global>
  /* ---- Scroll-entry animations ---- */
  [data-anim] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-anim].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-anim][data-delay="1"] { transition-delay: 0.10s; }
  [data-anim][data-delay="2"] { transition-delay: 0.20s; }
  [data-anim][data-delay="3"] { transition-delay: 0.30s; }
  [data-anim][data-delay="4"] { transition-delay: 0.40s; }
  [data-anim][data-delay="5"] { transition-delay: 0.50s; }

  /* Eyebrow transitions need to merge with data-anim */
  .sh__eyebrow[data-anim],
  .sr__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ---- Header overrides: light text on navy hero (before scroll) ----
     .header prefix bumps specificity to (0,4,0) to beat Astro-scoped
     Header.astro dark-theme rules which compile with [data-astro-cid]. ---- */
  .header.header--dark:not(.header--scrolled) .header__nav-link {
    color: rgba(250, 250, 249, 0.55);
  }

  .header.header--dark:not(.header--scrolled) .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__nav-link::after {
    background: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__cta {
    color: #FAFAF9;
    border-bottom-color: #FAFAF9;
  }

  .header.header--dark:not(.header--scrolled) .header__cta:hover {
    color: rgba(250, 250, 249, 0.7);
  }

  .header.header--dark:not(.header--scrolled) .header__cta-arrow {
    color: #FAFAF9;
  }

  @media (max-width: 768px) {
    .header--dark:not(.header--scrolled) .header__hamburger-wrap path {
      stroke: #FAFAF9;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-anim] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const animEls = document.querySelectorAll('[data-anim]');
  const animObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('is-visible');
        animObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -32px 0px' });

  animEls.forEach(el => animObserver.observe(el));
</script>
