  /* Right column */
  .services__right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    width: 736px;
    flex-shrink: 0;
    min-height: 620px;
  }

  /* Service row */
  .services__row {
    width: 100%;
    min-height: 155px;
    border-bottom: 1px solid #78716C;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0px;
    padding: 24px 0px;
    flex: 1;
    cursor: pointer;
  }

  /* Arrow line */
  .services__arrow {
    width: 52px;
    flex-shrink: 0;
    height: 2px;
    background-color: #A5B4A0;
    margin-right: 24px;
    position: relative;
    transform-origin: left center;
    will-change: transform;
  }

  .services__arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid #A5B4A0;
  }

  /* Text block */
  .services__row-text {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 40px;
    flex-grow: 1;
  }

  .services__row-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #F0F0F0;
    will-change: transform;
  }

  .services__desc-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .services__row--expanded .services__desc-wrap {
    grid-template-rows: 1fr;
  }

  .services__row-desc {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #F0F0F0;
    min-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.35s ease 0.15s;
  }

  .services__row--expanded .services__row-desc {
    opacity: 1;
  }

  .services__row--expanded .services__plus {
    transform: rotate(45deg);
  }

  /* Plus icon */
  .services__plus {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    width: 49px;
    height: 48px;
    position: relative;
  }

  .services__plus-v {
    position: absolute;
    width: 1px;
    height: 24px;
    background: #A5B4A0;
  }

  .services__plus-h {
    position: absolute;
    width: 24px;
    height: 1px;
    background: #A5B4A0;
  }

  .services__arrow {
    transition:
      background-color 0.35s ease,
      transform        0.4s  cubic-bezier(0.16, 1, 0.3, 1);
  }

  .services__row:hover .services__arrow {
    background-color: #FFFFFF;
    transform: scaleX(1.35);
  }

  .services__arrow::after {
    transition: border-left-color 0.35s ease;
  }

  .services__row:hover .services__arrow::after {
    border-left-color: #FFFFFF;
  }


  .services__plus-v,
  .services__plus-h {
    transition: background-color 0.35s ease;
  }

  .services__row:hover .services__plus-v,
  .services__row:hover .services__plus-h {
    background-color: #FFFFFF;
  }

