---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero Section: Split layout — logo top, text bottom -->
  <section class="hero">

    <!-- Top half: gray with logo -->
    <div class="hero__top">
      <img src="/images/placeholder-logo.webp" alt="Kukreja McFarlane Law" class="hero__logo" />
    </div>

    <!-- Gradient transition -->
    <div class="hero__gradient"></div>

    <!-- Bottom half: white with text -->
    <div class="hero__bottom">
      <div class="hero__content">
        <div class="hero__tagline-bar">
          <span class="hero__tagline">If you've been referred to us, we're ready to listen.</span>
        </div>
        <div class="hero__text-row">
          <h1 class="hero__headline">
            Trusted Counsel for Life's Most Complex Family Law Matters.
          </h1>
          <p class="hero__body">
            <span class="hero__body-lead">We make complex issues manageable.</span>
            <span class="hero__body-sub"> Kukreja McFarlane Law brings decades of experience
            to the families, individuals, and executives who demand both discretion and results.</span>
          </p>
        </div>
      </div>
    </div>

  </section>

  <!-- ============================================================ -->
  <!-- SECTION 1 — ACHIEVEMENTS BAR                                 -->
  <!-- ============================================================ -->
  <section class="achievements">
    <div class="achievements__row">

      <div class="stat-card stat-card--grow" data-anim>
        <span class="stat-card__value">40+ Years</span>
        <span class="stat-card__label">Combined Experience</span>
      </div>

      <div class="stat-card stat-card--grow" data-anim data-delay="1">
        <span class="stat-card__value">3</span>
        <span class="stat-card__label">Colorado Super Lawyers</span>
      </div>

      <div class="stat-card stat-card--grow" data-anim data-delay="2">
        <span class="stat-card__value">100%</span>
        <span class="stat-card__label">Family Law Focus</span>
      </div>

      <div class="stat-card stat-card--fixed" data-anim data-delay="3">
        <span class="stat-card__value">2024-26</span>
        <span class="stat-card__label">Best Lawyers of America</span>
      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 2 — ABOUT US                                         -->
  <!-- ============================================================ -->
  <section class="about">
    <div class="about__inner">

      <!-- Left column -->
      <div class="about__left">

        <!-- Left-left sub-column: eyebrow + body + link -->
        <div class="about__text-col">
          <span class="about__eyebrow" data-anim>About Us</span>

          <div class="about__copy-row">
            <p class="about__body" data-anim data-delay="1">
              We founded Kukreja McFarlane Law on a simple belief: clients facing the most
              consequential legal matters of their lives deserve more than competent
              representation — they deserve counsel who understands what's truly at
              stake. Our attorneys bring decades of experience in high-asset divorce,
              complex custody disputes, and sophisticated family law matters for
              Colorado's most discerning clients.
            </p>

            <a href="/about" class="about__link" data-anim data-delay="2">
              Learn More
              <span class="about__link-arrow">↗</span>
            </a>
          </div>
        </div>

      </div>

      <!-- Right column: bullet list -->
      <div class="about__right">

        <div class="about__bullet" data-anim>
          <div class="about__bullet-arrow"></div>
          <span class="about__bullet-text">Exclusively focused on high-stakes family law</span>
        </div>

        <div class="about__bullet" data-anim data-delay="1">
          <div class="about__bullet-arrow"></div>
          <span class="about__bullet-text">Trial-tested attorneys with a record of results</span>
        </div>

        <div class="about__bullet" data-anim data-delay="2">
          <div class="about__bullet-arrow"></div>
          <span class="about__bullet-text">Trusted by executives, business owners, and public figures</span>
        </div>

        <div class="about__bullet" data-anim data-delay="3">
          <div class="about__bullet-arrow"></div>
          <span class="about__bullet-text">Discreet, personalized counsel from day one</span>
        </div>

      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 3 — OUR TEAM (hidden from homepage, preserved for Team page) -->
  <!-- Team order: Raj, Kyle M., Kevin -->
  <!-- ============================================================ -->
