  <!-- ============================================================ -->
  <!-- SECTION 4 — SERVICES                                         -->
  <!-- ============================================================ -->
  <section class="services">
    <div class="services__inner">

      <!-- Left column -->
      <div class="services__left">
        <span class="services__eyebrow" data-anim>Services</span>
        <p class="services__body" data-anim data-delay="1">
          RKKM Law handles the full spectrum of family law matters — from complex
          asset division to high-conflict custody — with the discretion and rigor
          your situation demands.
        </p>
        <a href="/services" class="services__link" data-anim data-delay="2">
          Learn More
          <span class="services__link-arrow">↗</span>
        </a>
      </div>

      <!-- Right column: service accordion rows -->
      <div class="services__right">

        <!-- Row 1 — expanded by default -->
        <div class="services__row services__row--expanded" data-anim>
          <div class="services__arrow"></div>
          <div class="services__row-text">
            <span class="services__row-title">High-Asset Divorce</span>
            <div class="services__desc-wrap">
              <p class="services__row-desc">
                Representing individuals with significant marital estates through every
                stage of dissolution, including business valuations, property division,
                executive compensation analysis, and enforcement of marital agreements.
              </p>
            </div>
          </div>
          <div class="services__plus">
            <div class="services__plus-v"></div>
            <div class="services__plus-h"></div>
          </div>
        </div>

        <!-- Row 2 -->
        <div class="services__row" data-anim data-delay="1">
          <div class="services__arrow"></div>
          <div class="services__row-text">
            <span class="services__row-title">Child Custody &amp; Parenting</span>
            <div class="services__desc-wrap">
              <p class="services__row-desc">
                Strategic, compassionate representation in contested custody matters,
                parenting plan disputes, relocation cases, and modifications to existing orders.
              </p>
            </div>
          </div>
          <div class="services__plus">
            <div class="services__plus-v"></div>
            <div class="services__plus-h"></div>
          </div>
        </div>

        <!-- Row 3 -->
        <div class="services__row" data-anim data-delay="2">
          <div class="services__arrow"></div>
          <div class="services__row-text">
            <span class="services__row-title">Spousal Support &amp; Maintenance</span>
            <div class="services__desc-wrap">
              <p class="services__row-desc">
                Skilled advocacy in the determination, modification, and enforcement of
                spousal maintenance for clients on both sides of the negotiation.
              </p>
            </div>
          </div>
          <div class="services__plus">
            <div class="services__plus-v"></div>
            <div class="services__plus-h"></div>
          </div>
        </div>

        <!-- Row 4 -->
        <div class="services__row" data-anim data-delay="3">
          <div class="services__arrow"></div>
          <div class="services__row-text">
            <span class="services__row-title">Mediation &amp; Alternative Dispute Resolution</span>
            <div class="services__desc-wrap">
              <p class="services__row-desc">
                Confidential, efficient resolution of family law matters outside of court —
                led by attorneys with formal ADR training and decades of negotiation experience.
              </p>
            </div>
          </div>
          <div class="services__plus">
            <div class="services__plus-v"></div>
            <div class="services__plus-h"></div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 5 — REPRESENTATION MATTERS                           -->
  <!-- ============================================================ -->
  <section class="representation">
    <div class="representation__inner">

      <!-- Section header -->
      <div class="representation__header">
        <span class="representation__eyebrow" data-anim>Representation Matters</span>
        <h2 class="representation__heading" data-anim data-delay="1">The Cases We Handle</h2>
        <p class="representation__subtext" data-anim data-delay="2">Our firm is retained for matters where the stakes — financial, reputational, and personal — demand the highest level of counsel. While we protect the identities of every client, the nature of our work speaks for itself.</p>
      </div>

      <!-- Matter cards grid -->
      <div class="representation__grid">

        <div class="representation__card" data-anim>
          <span class="representation__card-eyebrow">High-Asset Dissolution</span>
          <h3 class="representation__card-title">$40M+ Marital Estate Division</h3>
          <p class="representation__card-desc">Represented a tech executive in the dissolution of a marriage involving multiple business entities, stock options, deferred compensation, and out-of-state real property holdings.</p>
        </div>

        <div class="representation__card" data-anim data-delay="1">
          <span class="representation__card-eyebrow">Executive Custody Dispute</span>
          <h3 class="representation__card-title">International Relocation &amp; Parenting</h3>
          <p class="representation__card-desc">Secured a favorable parenting plan for a C-suite client whose former spouse sought to relocate internationally with minor children, involving coordination across multiple jurisdictions.</p>
        </div>

        <div class="representation__card" data-anim data-delay="2">
          <span class="representation__card-eyebrow">Business Owner Divorce</span>
          <h3 class="representation__card-title">Closely-Held Business Valuation</h3>
          <p class="representation__card-desc">Protected the ownership interest and operational continuity of a multi-generational family business during a contested divorce involving complex forensic accounting.</p>
        </div>

        <div class="representation__card" data-anim data-delay="3">
          <span class="representation__card-eyebrow">Public Figure Matter</span>
          <h3 class="representation__card-title">Discreet Resolution Under Public Scrutiny</h3>
          <p class="representation__card-desc">Guided a well-known Colorado professional through a high-profile dissolution, managing media exposure while achieving an expedient and confidential settlement.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 6 — MID-PAGE CTA BANNER                             -->
  <!-- ============================================================ -->
  <section class="cta-banner">

    <!-- Background image layer -->
    <div class="cta-banner__bg"></div>

    <!-- Dark shade overlay -->
    <div class="cta-banner__overlay"></div>

    <!-- Content -->
    <div class="cta-banner__content">

      <!-- Top row: headline -->
      <div class="cta-banner__top">
        <h2 class="cta-banner__headline" data-anim>
          When the Stakes Are High, Experience Is Everything.
        </h2>
      </div>

      <!-- Bottom row: subtext + CTA -->
      <div class="cta-banner__bottom">
        <p class="cta-banner__subtext" data-anim data-delay="1">
          Kukreja McFarlane Law represents clients who cannot afford the wrong outcome. Schedule a confidential consultation today.
        </p>
        <a href="/contact" class="cta-banner__link" data-anim data-delay="2">
          Schedule a Consultation
          <span class="cta-banner__link-arrow">↗</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECTION 7 — CONTACT US                                       -->
  <!-- ============================================================ -->
  <section class="contact">
    <div class="contact__inner">

      <!-- Left column: form -->
      <div class="contact__left">

        <div class="contact__header">
          <span class="contact__eyebrow" data-anim>Get In Touch</span>
          <h2 class="contact__heading" data-anim data-delay="1">Contact Us</h2>
          <p class="contact__subtext" data-anim data-delay="2">Your matter is confidential. Reach out to schedule a consultation and one of our attorneys will be in touch shortly.</p>
        </div>

        <div class="contact__fields" data-anim data-delay="3">
          <input class="contact__input" type="text" placeholder="Full Name*" />
          <input class="contact__input" type="text" placeholder="Phone Number*" />
          <input class="contact__input" type="email" placeholder="Email Address*" />
          <input class="contact__input" type="text" placeholder="Message*" />
        </div>

        <div class="contact__submit" data-anim data-delay="4">
          Request A Consultation
          <span class="contact__submit-arrow">↗</span>
        </div>

      </div>

      <!-- Right column: contact info panel -->
      <div class="contact__right" data-anim data-delay="2">

        <h3 class="contact__info-heading">Contact Information</h3>

        <div class="contact__info-rows">

          <div class="contact__info-row">
            <div class="contact__icon-box">
              <i class="contact__icon fa-solid fa-envelope"></i>
            </div>
            <span class="contact__info-text">info@rkkmlaw.com</span>
          </div>

          <div class="contact__info-row">
            <div class="contact__icon-box">
              <i class="contact__icon fa-solid fa-phone"></i>
            </div>
            <span class="contact__info-text">+720 123 4567</span>
          </div>

          <div class="contact__info-row">
            <div class="contact__icon-box">
              <i class="contact__icon fa-solid fa-location-dot"></i>
            </div>
            <span class="contact__info-text">Office Address TBD Denver, CO 80205</span>
          </div>

          <div class="contact__info-row">
            <div class="contact__icon-box">
              <i class="contact__icon fa-solid fa-clock"></i>
            </div>
            <span class="contact__info-text">Monday - Friday; 8:00am - 5:00pm</span>
          </div>

        </div>

        <div class="contact__divider"></div>

      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
  }

  .hero__top {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #D5D3CF;
    padding: 80px 80px 40px;
    min-height: 45vh;
  }

  .hero__logo {
    max-width: 168px;
    max-height: 168px;
    object-fit: contain;
    border-radius: 50%;
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__gradient {
    height: 120px;
    background: linear-gradient(to bottom, #D5D3CF 0%, #E6E5E2 35%, #F5F4F2 65%, #FFFFFF 100%);
    flex-shrink: 0;
  }

  .hero__bottom {
    background: #FFFFFF;
    padding: 0 80px 80px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .hero__text-row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    gap: 40px;
  }

  .hero__tagline-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid #D6D3D1;
    width: 100%;
  }

  .hero__tagline {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0.02em;
    color: #78716C;
    font-style: italic;
  }

  .hero__headline {
    max-width: 819px;
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 70px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
  }

  .hero__body {
    width: 480px;
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    line-height: 27px;
    letter-spacing: -0.02em;
    color: #44403C;
    flex-shrink: 0;
  }

  .hero__body-lead {
    font-weight: 600;
    color: #1C1917;
  }

  .hero__body-sub {
    font-weight: 300;
    color: #78716C;
  }

  /* ============================================================
     SECTION 1 — ACHIEVEMENTS BAR
  ============================================================ */
  .achievements {
    width: 100%;
    background: #FAFAF9;
    padding: 40px 80px;
  }

  .achievements__row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 24px;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 24px 0px;
    gap: 8px;
    border-bottom: 1px solid #78716C;
    position: relative;
    transition: border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Navy sweep line grows left → right over the stone border on hover */
  .stat-card::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background: #1C2E4A;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stat-card:hover::after {
    transform: scaleX(1);
  }

  .stat-card--grow {
    flex-grow: 1;
  }

  .stat-card--fixed {
    width: 300px;
    flex-shrink: 0;
  }

  .stat-card__value {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C2E4A;
    display: inline-block;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stat-card:hover .stat-card__value {
    transform: translateY(-4px);
  }

  .stat-card__label {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 140%;
    letter-spacing: -0.03em;
    color: #78716C;
    transition: color 0.35s ease;
  }

  .stat-card:hover .stat-card__label {
    color: #1C2E4A;
  }

  /* ============================================================
     SECTION 2 — ABOUT US
  ============================================================ */
  .about {
    width: 100%;
    background: #FAFAF9;
    padding: 40px 80px;
    min-height: 755px;
    overflow: hidden;
  }

  .about__inner {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }

  /* Left column */
  .about__left {
    width: 872px;
    flex-shrink: 0;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 72px;
  }

  .about__text-col {
    width: 600px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 13px;
  }

  .about__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716C;
  }
  .about__eyebrow:hover { color: #1C2E4A; letter-spacing: 0.14em; }

  .about__copy-row {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 24px;
    width: 100%;
  }

  .about__body {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 140%;
    letter-spacing: -0.03em;
    color: #0C0A09;
    flex: 1;
  }

  .about__link {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding: 0px 16px;
    border-bottom: 1px solid #1C2E4A;
    width: fit-content;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
    transition: color 0.3s ease;
  }

  .about__link:hover {
    color: #1C2E4A;
  }

  .about__link-arrow {
    font-size: 14px;
    color: #1C2E4A;
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about__link:hover .about__link-arrow {
    transform: translate(3px, -3px);
  }

  /* Right column */
  .about__right {
    width: 408px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 24px 0px;
    gap: 104px;
    border-left: 1px solid #78716C;
    height: 675px;
  }

  .about__bullet {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-left: 40px;
    gap: 24px;
    width: 100%;
  }

  .about__bullet-arrow {
    width: 52px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    position: relative;
    height: 2px;
    background-color: #A5B4A0;
    transform-origin: left center;
    will-change: transform;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.35s ease;
  }

  .about__bullet:hover .about__bullet-arrow {
    transform: scaleX(1.38);
    background-color: #1C2E4A;
  }

  .about__bullet-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid #A5B4A0;
    transition: border-left-color 0.35s ease;
  }

  .about__bullet:hover .about__bullet-arrow::after {
    border-left-color: #1C2E4A;
  }

  .about__bullet-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
    flex-grow: 1;
    will-change: transform;
    transition: color 0.35s ease;
  }

  .about__bullet:hover .about__bullet-text {
    color: #1C2E4A;
  }

  /* ============================================================
     SECTION 3 — OUR TEAM
  ============================================================ */
  .team {
    width: 100%;
    background: #FAFAF9;
    padding: 40px 80px;
    overflow: hidden;
  }

  .team__inner {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0px;
  }

  /* Section header */
  .team__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: 40px;
    border-bottom: 1px solid #78716C;
