    color: #78716C;
    margin-bottom: 8px;
  }
  .team__eyebrow:hover { color: #1C2E4A; letter-spacing: 0.14em; }

  .team__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 32px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
  }

  .team__link {
    position: absolute;
    right: 0;
    bottom: 40px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding: 0px 16px;
    border-bottom: 1px solid #1C2E4A;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
  }

  .team__link-arrow {
    font-size: 14px;
    color: #1C2E4A;
  }

  /* Row 1 — 3 larger cards */
  .team__row--large {
    display: flex;
    flex-direction: row;
    gap: 18px;
    margin-top: 40px;
    width: 100%;
  }

  /* Row 2 — 4 smaller cards */
  .team__row--small {
    display: flex;
    flex-direction: row;
    gap: 16px;
    margin-top: 36px;
    width: 100%;
  }

  /* Shared card styles */
  .team__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: 1;
    overflow: hidden;
    cursor: pointer;
  }

  .team__photo {
    width: 100%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
    display: block;
    transition: transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Large row: ~361px wide × 358px tall at desktop ≈ 1:1 */
  .team__row--large .team__photo {
    aspect-ratio: 1 / 1;
  }

  /* Small row: ~268px wide × 358px tall at desktop ≈ 3:4 */
  .team__row--small .team__photo {
    aspect-ratio: 3 / 4;
  }

  .team__card:hover .team__photo {
    transform: scale(1.04);
  }

  .team__name {
    transition: color 0.3s ease;
  }

  .team__card:hover .team__name {
    color: #1C2E4A;
  }

  .team__link {
    transition: color 0.3s ease;
  }

  .team__link:hover {
    color: #1C2E4A;
  }

  .team__link-arrow {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team__link:hover .team__link-arrow {
    transform: translate(3px, -3px);
  }

  /* Info block — large cards */
  .team__info {
    display: flex;
    flex-direction: column;
    padding: 16px 0px;
    gap: 4px;
    width: 100%;
  }

  /* Info block — small cards */
  .team__info--small {
    gap: 2px;
  }

  .team__name {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #0C0A09;
  }

  /* Partner role — bold black */
  .team__title--role {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #0C0A09;
  }

  /* Partner specialty — gray */
  .team__title--specialty {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 130%;
    letter-spacing: -0.03em;
