---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts, formatPublishedDate } from '../../data/blogPosts';
---

<BaseLayout
  title="KM Law Blog — Insights from Kukreja McFarlane Law"
  description="Practical guidance from Kukreja McFarlane Law on high-asset divorce, custody, spousal support, and mediation for Colorado clients."
  headerTheme="dark"
  noIndex
>
  <!-- ── Navy Hero ────────────────────────────────────────────── -->
  <section class="blog-hero">
    <div class="blog-hero__bottom">
      <div class="blog-hero__copy">
        <span class="blog-hero__eyebrow">KM Law Blog</span>
        <h1 class="blog-hero__headline">Insights From&nbsp;KM&nbsp;Law.</h1>
        <p class="blog-hero__subtext">
          Practical guidance from our attorneys on high-asset divorce, complex
          custody, spousal support, and mediation for Colorado clients.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Archive Grid ─────────────────────────────────────────── -->
  <section class="blog-archive">
    <div class="blog-archive__inner">
      <div class="blog-archive__grid">
        {blogPosts.map((post, i) => (
          <a href={`/blog/${post.slug}`} class="post-card" data-anim data-delay={String((i % 4) + 1)}>
            <div class="post-card__image-wrap">
              <img src={post.featuredImage} alt={post.featuredImageAlt} class="post-card__image" />
              <span class="post-card__category">{post.category}</span>
            </div>
            <div class="post-card__body">
              <h2 class="post-card__title">{post.title}</h2>
              <p class="post-card__excerpt">{post.excerpt}</p>
              <div class="post-card__meta">
                <span class="post-card__meta-item">{formatPublishedDate(post.publishedDate)}</span>
                <span class="post-card__meta-dot" aria-hidden="true"></span>
                <span class="post-card__meta-item">{post.readTime}</span>
              </div>
              <div class="post-card__cta">
                <span class="post-card__cta-text">Read Article</span>
                <svg class="post-card__cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero — matches the About / Team / Contact pattern ── */
  .blog-hero {
    width: 100%;
    height: 520px;
    background: #1B3B49;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0 max(80px, calc((100vw - 1600px) / 2));
    box-sizing: border-box;
  }

  .blog-hero__bottom {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    width: 100%;
    flex-grow: 1;
    padding-bottom: calc(40px + 4rem);
    max-width: 1600px;
  }

  .blog-hero__copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 720px;
  }

  .blog-hero__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 250, 249, 0.6);
  }

  .blog-hero__headline {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 70px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    margin: 0;
  }

  .blog-hero__subtext {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 170%;
    letter-spacing: -0.02em;
    color: rgba(250, 250, 249, 0.65);
    margin: 8px 0 0;
    max-width: 600px;
  }

  /* ── Archive section ── */
  .blog-archive {
    width: 100%;
    background: #F5F5F4;
    padding: 64px 80px 88px;
    box-sizing: border-box;
  }

  .blog-archive__inner {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
  }

  .blog-archive__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  /* ── Post card ── */
  .post-card {
    display: flex;
    flex-direction: column;
    background: #FAFAF9;
    border: 1px solid rgba(120, 113, 108, 0.14);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(27, 59, 73, 0.10);
    border-color: rgba(27, 59, 73, 0.3);
  }

  .post-card__image-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .post-card__image {
    transform: scale(1.04);
  }

  .post-card__category {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    background: #1B3B49;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FAFAF9;
  }

  .post-card__body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .post-card__title {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 130%;
    letter-spacing: -0.03em;
    color: #1C1917;
    transition: color 0.3s ease;
  }

  .post-card:hover .post-card__title {
    color: #1B3B49;
  }

  .post-card__excerpt {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 160%;
    letter-spacing: -0.02em;
    color: #57534E;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
  }

  .post-card__meta-item {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #78716C;
  }

  .post-card__meta-dot {
    width: 3px;
    height: 3px;
    background: #78716C;
    border-radius: 50%;
  }

  /* Read-article CTA — same text + arrow pattern as site-wide */
  .post-card__cta {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 12px;
    padding-top: 18px;
    border-top: 1px solid rgba(120, 113, 108, 0.12);
  }

  .post-card__cta-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
    transition: color 0.3s ease;
  }

  .post-card:hover .post-card__cta-text {
    color: #1B3B49;
  }

  .post-card__cta-arrow {
    width: 14px;
    height: 14px;
    color: #1B3B49;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .post-card__cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .blog-hero { padding: 0 60px; }
    .blog-hero__headline { font-size: 60px; }
    .blog-archive { padding: 56px 60px 72px; }
    .blog-archive__grid { gap: 24px; }
  }

  @media (max-width: 1024px) {
    .blog-hero { padding: 0 40px; }
    .blog-hero__headline { font-size: 52px; }
    .blog-archive { padding: 48px 40px 64px; }
    .blog-archive__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .blog-hero {
      padding: 0 24px;
      height: auto;
      min-height: 380px;
      justify-content: flex-end;
    }
    .blog-hero__bottom {
      flex-grow: 0;
      padding-top: 24px;
      padding-bottom: 32px;
    }
    .blog-hero__headline { font-size: 30px; }
    .blog-hero__subtext { font-size: 14.5px; }

    .blog-archive { padding: 40px 24px 56px; }
    .blog-archive__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .post-card__title { font-size: 20px; }
    .post-card__body { padding: 24px 24px 28px; }
  }

  @media (max-width: 480px) {
    .blog-hero { padding: 0 16px; min-height: 340px; }
    .blog-hero__headline { font-size: 26px; }
    .blog-archive { padding: 32px 16px 48px; }
    .post-card__body { padding: 22px 20px 24px; }
  }
</style>
