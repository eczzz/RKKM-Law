---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts, formatPublishedDate, sanitizeBlogBody } from '../../data/blogPosts';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

function slugifyHeading(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

// Pull h2 headings out of the body to build the TOC, and inject ids back
// in so the anchor links work.
const tocItems: { id: string; text: string }[] = [];
const sanitizedBody = sanitizeBlogBody(post.body);
const bodyWithIds = sanitizedBody.replace(/<h2([^>]*)>([\s\S]*?)<\/h2>/g, (_match, attrs, inner) => {
  const text = inner.replace(/<[^>]*>/g, '').trim();
  const id = slugifyHeading(text);
  tocItems.push({ id, text });
  return `<h2${attrs} id="${id}">${inner}</h2>`;
});

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;

const encodedUrl = encodeURIComponent(canonicalUrl);
const encodedTitle = encodeURIComponent(post.title);
const shareLinks = {
  x: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
};
---

<BaseLayout
  title={`${post.title} | KM Law Blog`}
  description={post.excerpt}
  headerTheme="dark"
>
  <!-- ── Navy post-header band — matches the site's hero pattern ── -->
  <section class="post-hero">
    <div class="post-hero__inner">
      <a href="/blog" class="post-hero__back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 1L1 13M1 13H11M1 13V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back to KM Law Blog
      </a>
      <span class="post-hero__category">{post.category}</span>
      <h1 class="post-hero__title">{post.title}</h1>
      <div class="post-hero__meta">
        <span class="post-hero__meta-item post-hero__meta-item--author">{post.author}</span>
        <span class="post-hero__meta-dot" aria-hidden="true"></span>
        <span class="post-hero__meta-item">{formatPublishedDate(post.publishedDate)}</span>
        <span class="post-hero__meta-dot" aria-hidden="true"></span>
        <span class="post-hero__meta-item">{post.readTime}</span>
      </div>
    </div>
  </section>

  <!-- ── Body section ── -->
  <article class="post">
    <div class="post__container">

      <!-- Featured image -->
      <div class="post__image-wrap">
        <img src={post.featuredImage} alt={post.featuredImageAlt} class="post__image" />
      </div>

      <!-- Share row — under the image -->
      <div class="post__share" data-share-url={canonicalUrl}>
        <span class="post__share-label">Share This Post</span>
        <div class="post__share-buttons">
          <a href={shareLinks.x} target="_blank" rel="noopener noreferrer" class="post__share-btn" aria-label="Share on X">
            <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
          </a>
          <a href={shareLinks.facebook} target="_blank" rel="noopener noreferrer" class="post__share-btn" aria-label="Share on Facebook">
            <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
          </a>
          <a href={shareLinks.linkedin} target="_blank" rel="noopener noreferrer" class="post__share-btn" aria-label="Share on LinkedIn">
            <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
          </a>
          <button type="button" class="post__share-btn post__share-copy" aria-label="Copy link to clipboard">
            <i class="fa-solid fa-link" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <!-- Table of contents -->
      {tocItems.length > 0 && (
        <aside class="post__toc" aria-label="Table of contents">
          <div class="post__toc-accent" aria-hidden="true"></div>
          <div class="post__toc-content">
            <span class="post__toc-eyebrow">In This Article</span>
            <h2 class="post__toc-heading">Table of Contents</h2>
            <ol class="post__toc-list">
              {tocItems.map((item, i) => (
                <li class="post__toc-item">
                  <a href={`#${item.id}`} class="post__toc-link">
                    <span class="post__toc-number">{String(i + 1).padStart(2, '0')}</span>
                    <span class="post__toc-text">{item.text}</span>
                    <svg class="post__toc-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </aside>
      )}

      <!-- Body -->
      <div class="post__body" set:html={bodyWithIds}></div>

      <!-- Back-to-blog footer -->
      <div class="post__footer">
        <a href="/blog" class="post__footer-link">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 1L1 13M1 13H11M1 13V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to KM Law Blog
        </a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  /* ── Navy header band ── */
  .post-hero {
    width: 100%;
    background: #1B3B49;
    padding: 0 max(80px, calc((100vw - 1600px) / 2));
    box-sizing: border-box;
    padding-top: 220px; /* clears the fixed Header */
    padding-bottom: 80px;
  }

  .post-hero__inner {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .post-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 13px;
    line-height: 21px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(250, 250, 249, 0.6);
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-hero__back:hover {
    color: #FAFAF9;
    transform: translateX(-3px);
  }

  .post-hero__back svg {
    width: 14px;
    height: 14px;
  }

  .post-hero__category {
    display: inline-flex;
    padding: 6px 14px;
    background: rgba(250, 250, 249, 0.08);
    border: 1px solid rgba(250, 250, 249, 0.2);
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(250, 250, 249, 0.85);
  }

  .post-hero__title {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 54px;
    line-height: 115%;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .post-hero__meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .post-hero__meta-item {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.01em;
    color: rgba(250, 250, 249, 0.65);
  }

  .post-hero__meta-item--author {
    color: #FAFAF9;
    font-weight: 500;
  }

  .post-hero__meta-dot {
    width: 3px;
    height: 3px;
    background: rgba(250, 250, 249, 0.3);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Body section ── */
  .post {
    width: 100%;
    background: #F5F5F4;
    padding: 64px 80px 96px;
    box-sizing: border-box;
  }

  .post__container {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  /* Featured image */
  .post__image-wrap {
    width: 100%;
    margin-bottom: 24px;
    overflow: hidden;
  }

  .post__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  /* Share row */
  .post__share {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 18px 0 22px;
    border-bottom: 1px solid rgba(120, 113, 108, 0.2);
    margin-bottom: 48px;
  }

  .post__share-label {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12px;
    line-height: 18px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716C;
  }

  .post__share-buttons {
    display: flex;
    flex-direction: row;
    gap: 10px;
  }

  .post__share-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(120, 113, 108, 0.3);
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #57534E;
    text-decoration: none;
    padding: 0;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease,
      background 0.3s ease,
      color 0.3s ease;
  }

  .post__share-btn:hover {
    transform: translateY(-2px);
    border-color: #1B3B49;
    background: #1B3B49;
    color: #FAFAF9;
  }

  .post__share-btn i {
    font-size: 14px;
    line-height: 1;
  }

  .post__share-copy.is-copied {
    border-color: #1B3B49;
    background: #1B3B49;
    color: #FAFAF9;
  }

  /* ── Table of Contents ── */
  .post__toc {
    position: relative;
    background: #FAFAF9;
    border: 1px solid rgba(120, 113, 108, 0.18);
    overflow: hidden;
    margin: 0 0 56px;
    display: flex;
    flex-direction: row;
  }

  .post__toc-accent {
    flex-shrink: 0;
    width: 4px;
    background: #99AD8C;
  }

  .post__toc-content {
    padding: 28px 32px;
    flex: 1;
  }

  .post__toc-eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716C;
    margin-bottom: 6px;
  }

  .post__toc-heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
    margin: 0 0 18px;
  }

  .post__toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .post__toc-item {
    border-top: 1px solid rgba(120, 113, 108, 0.12);
  }

  .post__toc-item:first-child {
    border-top: none;
  }

  .post__toc-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 22px;
    letter-spacing: -0.02em;
    color: #44403C;
    text-decoration: none;
    transition: color 0.3s ease, padding-left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post__toc-link:hover {
    color: #1B3B49;
    padding-left: 6px;
  }

  .post__toc-number {
    flex-shrink: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: #78716C;
    min-width: 26px;
    transition: color 0.3s ease;
  }

  .post__toc-link:hover .post__toc-number {
    color: #1B3B49;
  }

  .post__toc-text {
    flex: 1;
  }

  .post__toc-arrow {
    flex-shrink: 0;
    color: #1B3B49;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post__toc-link:hover .post__toc-arrow {
    opacity: 1;
    transform: translate(3px, -3px);
  }

  /* ── Body content ── */
  .post__body {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 170%;
    letter-spacing: -0.02em;
    color: #44403C;
  }

  .post__body :global(p) {
    margin: 0 0 24px;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  .post__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .post__body :global(h2) {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 28px;
    line-height: 120%;
    letter-spacing: -0.03em;
    color: #1C1917;
    margin: 48px 0 18px;
    scroll-margin-top: 100px;
  }

  .post__body :global(h3) {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 130%;
    letter-spacing: -0.03em;
    color: #1C1917;
    margin: 36px 0 14px;
    scroll-margin-top: 100px;
  }

  .post__body :global(a) {
    color: #1B3B49;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .post__body :global(a:hover) {
    color: #0C0A09;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }

  .post__body :global(ul) {
    list-style: disc;
  }

  .post__body :global(ol) {
    list-style: decimal;
  }

  .post__body :global(li) {
    margin-bottom: 8px;
  }

  .post__body :global(blockquote) {
    margin: 32px 0;
    padding: 4px 0 4px 24px;
    border-left: 3px solid #99AD8C;
    font-style: italic;
    color: #1C1917;
  }

  /* ── Footer back-link ── */
  .post__footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid rgba(120, 113, 108, 0.2);
  }

  .post__footer-link {
    display: inline-flex;
    align-items: center;
    gap: 24px;
    padding: 0 16px;
    border-bottom: 1px solid #1B3B49;
    width: fit-content;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post__footer-link:hover {
    color: #1B3B49;
    transform: translateX(-3px);
  }

  .post__footer-link svg {
    width: 14px;
    height: 14px;
    color: #1B3B49;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .post-hero { padding-left: 60px; padding-right: 60px; padding-top: 200px; padding-bottom: 72px; }
    .post-hero__title { font-size: 46px; }
    .post { padding: 56px 60px 80px; }
  }

  @media (max-width: 1024px) {
    .post-hero { padding-left: 40px; padding-right: 40px; padding-top: 180px; padding-bottom: 64px; }
    .post-hero__title { font-size: 40px; }
    .post { padding: 48px 40px 72px; }
    .post__toc-content { padding: 24px 26px; }
    .post__body { font-size: 16px; }
    .post__body :global(h2) { font-size: 26px; }
  }

  @media (max-width: 768px) {
    .post-hero {
      padding-left: 24px;
      padding-right: 24px;
      padding-top: 140px;
      padding-bottom: 48px;
    }
    .post-hero__inner { gap: 16px; }
    .post-hero__title { font-size: 30px; }
    .post-hero__meta { gap: 10px; }
    .post-hero__meta-item { font-size: 13px; }

    .post { padding: 40px 24px 64px; }
    .post__image-wrap { margin-bottom: 20px; }
    .post__share {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 36px;
    }
    .post__toc { margin-bottom: 36px; }
    .post__toc-content { padding: 22px 22px; }
    .post__toc-heading { font-size: 20px; }
    .post__toc-link { font-size: 15px; padding: 12px 0; }

    .post__body :global(h2) { font-size: 24px; margin: 36px 0 14px; }
    .post__body :global(h3) { font-size: 20px; }
    .post__footer { margin-top: 48px; }
  }

  @media (max-width: 480px) {
    .post-hero { padding-left: 16px; padding-right: 16px; padding-top: 120px; padding-bottom: 36px; }
    .post-hero__title { font-size: 26px; }

    .post { padding: 32px 16px 52px; }
    .post__toc-accent { width: 3px; }
    .post__toc-content { padding: 20px 18px; }
    .post__share-btn { width: 38px; height: 38px; }
    .post__body { font-size: 15.5px; line-height: 26px; }
  }
</style>

<script>
  // Copy-link button — replaces the icon with a checkmark briefly on success.
  // Re-bound on every astro:page-load so it survives view transitions.
  function setupCopyLinkButtons() {
    document.querySelectorAll<HTMLButtonElement>('.post__share-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const wrapper = btn.closest('.post__share') as HTMLElement | null;
        const url = wrapper?.dataset.shareUrl ?? window.location.href;
        const icon = btn.querySelector<HTMLElement>('i');
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add('is-copied');
          if (icon) icon.className = 'fa-solid fa-check';
          setTimeout(() => {
            btn.classList.remove('is-copied');
            if (icon) icon.className = 'fa-solid fa-link';
          }, 1800);
        } catch {
          // Clipboard blocked — silent no-op.
        }
      });
    });
  }

  document.addEventListener('astro:page-load', setupCopyLinkButtons);
</script>
