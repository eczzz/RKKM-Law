---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamMemberHero from '../../components/team-member/TeamMemberHero.astro';
import TeamMemberBio from '../../components/team-member/TeamMemberBio.astro';
import TeamCTA from '../../components/team/TeamCTA.astro';

// ---- NON-EQUITY MEMBERS ----------------------------------------------------
// Each entry renders its own bio section. Replace placeholder bios / photos
// with real content as it becomes available from the client.
interface MemberData {
  id: string;
  fullName: string;
  role: string;
  image: string;
  imageAlt: string;
  bio: string[];
  linkedin?: string;
}

const members: MemberData[] = [
  {
    id: 'kevin-keyes',
    fullName: 'Kevin Keyes',
    role: 'Non-Equity Member',
    image: '/images/kevin-keyes-km-law-firm-bio.webp',
    imageAlt: 'Kevin Keyes, Non-Equity Member at KM Law',
    // TODO: Add Kevin's LinkedIn URL when provided by client.
    // linkedin: 'https://www.linkedin.com/in/kevin-keyes-60631939/',
    bio: [
      "Kevin Keyes is a Non-Equity Member of Kukreja McFarlane Law with a deep commitment to legal advocacy and a diverse background spanning various legal disciplines. Throughout his legal career he has demonstrated a dedication to providing comprehensive and effective representation to all clients.",
      "Kevin earned his Juris Doctor from the University of Denver Sturm College of Law, where he was recognized as Outstanding Graduating Law Student by the Student Bar Association. He went on to obtain an LL.M. in Taxation from the University of Denver Sturm College of Law. Prior to his legal studies, Kevin completed a Bachelor of Arts in Theater from the University of Colorado in Boulder.",
      "Kevin has extensive courtroom litigation experience, having served as a Deputy District Attorney for the 18th Judicial District in Colorado, where he managed a caseload of over 500 files and completed over 35 jury trials. He also served as a Staff Attorney for the Department of Veterans Affairs.",
    ],
  },
  {
    id: 'heather-sanders',
    fullName: 'Heather Sanders',
    role: 'Non-Equity Member',
    image: '/images/heather-sanders-KM-law-firm-bio.webp',
    imageAlt: 'Heather Sanders, Non-Equity Member at KM Law',
    // TODO: Add Heather's LinkedIn URL when provided by client.
    // linkedin: '',
    bio: [
      "Heather Sanders is a Non-Equity Member of Kukreja McFarlane Law, bringing patience, understanding, and careful attention to detail to every client she represents. She prides herself on being attentive, responsive, sensitive, and direct with clients navigating some of the most difficult moments of their lives.",
      "Heather earned her Juris Doctor from Georgetown University Law Center in 2010 and her Bachelor of Arts in Sociology from the University of Virginia, where she wrote her thesis on the changing roles of parenthood in the context of divorce. After law school she clerked for the Honorable James C. Klein of Colorado's Twentieth Judicial District in Boulder.",
      "Heather has comprehensive experience across dissolution, high-conflict litigation, collaborative cases, mediation, and appellate work, with particular depth in complex financial issues — including the division and valuation of business interests, trusts, privately held stock, and high-level compensation packages.",
    ],
  },
];

const description =
  'Meet Kevin Keyes and Heather Sanders, Non-Equity Members at Kukreja McFarlane Law, supporting the firm\'s family law practice in Denver, Colorado.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: 'https://www.rkkmlaw.com/team/non-equity-members',
  name: 'Non-Equity Members — KM Law',
  description,
  isPartOf: { '@id': 'https://www.rkkmlaw.com/#organization' },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: members.map((m, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Person',
        name: m.fullName,
        jobTitle: m.role,
        image: `https://www.rkkmlaw.com${m.image}`,
        url: `https://www.rkkmlaw.com/team/non-equity-members#${m.id}`,
        worksFor: { '@id': 'https://www.rkkmlaw.com/#organization' },
        ...(m.linkedin ? { sameAs: [m.linkedin] } : {}),
      },
    })),
  },
};
---

<BaseLayout
  title="Non-Equity Members — KM Law"
  description={description}
  headerTheme="dark"
  schema={schema}
>
  <TeamMemberHero headline="Non-Equity Members." scrollTo={`#${members[0].id}`} />

  {members.map((m, i) => (
    <TeamMemberBio
      id={m.id}
      name={m.fullName}
      role={m.role}
      image={m.image}
      imageAlt={m.imageAlt}
      bio={m.bio}
      linkedin={m.linkedin}
      showCta={i === members.length - 1}
    />
  ))}

  <TeamCTA />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .member-bio__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Offset anchor jumps so the fixed header doesn't cover the target */
  .member-bio {
    scroll-margin-top: 100px;
  }
</style>

