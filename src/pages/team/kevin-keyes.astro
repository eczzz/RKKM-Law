---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamMemberHero from '../../components/team-member/TeamMemberHero.astro';
import TeamMemberBio from '../../components/team-member/TeamMemberBio.astro';
import TeamMemberCredentials from '../../components/team-member/TeamMemberCredentials.astro';
import TeamMemberPracticeAreas from '../../components/team-member/TeamMemberPracticeAreas.astro';
import TeamCTA from '../../components/team/TeamCTA.astro';

// ---- TEMPLATE DATA ---------------------------------------------------------
// To add a new attorney: copy this file, rename it, and replace the values in
// the `member` object below. The components handle all rendering.
const member = {
  fullName: 'Kevin Keyes',
  shortName: 'Kevin',
  role: 'Equity Member',
  badge: 'Our Team',
  image: '/Kevin-image.webp',
  imageAlt: 'Kevin Keyes, Equity Member at KM Law',
  linkedin: 'https://www.linkedin.com/in/kevin-keyes-60631939/',
  heroHeadline: 'Meet Kevin.',
  bio: [
    "Kevin Keyes is an Equity Member of Kukreja McFarlane Law with a deep commitment to legal advocacy and a diverse background spanning various legal disciplines. Throughout his legal career he has demonstrated a dedication to providing comprehensive and effective representation to all clients.",
    "Kevin earned his Juris Doctor from the University of Denver Sturm College of Law, where he was recognized as Outstanding Graduating Law Student by the Student Bar Association. He went on to obtain an LL.M. in Taxation from the University of Denver Sturm College of Law, receiving a scholarship awarded by the Director of the Graduate Tax Program. Prior to his legal studies, Kevin completed a Bachelor of Arts in Theater from the University of Colorado in Boulder, which provided him with a unique foundation for effective communication, presentation, and advocacy.",
    "Kevin has extensive courtroom litigation experience, having served as a Deputy District Attorney for the 18th Judicial District in Colorado, where he managed a caseload of over 500 files and completed over 35 jury trials. He also served as a Staff Attorney for the Department of Veterans Affairs, handling labor and employment matters and serving as Acting Deputy Chief Counsel.",
    "Kevin firmly believes in providing each client with effective legal guidance, understanding, compassion, and advocacy.",
  ],
  practiceAreas: [
    { title: 'High-Asset Divorce', href: '/services#high-asset-divorce' },
    { title: 'Child Custody & Parenting', href: '/services#child-custody' },
    { title: 'Mediation & Arbitration', href: '/services#mediation' },
    { title: 'View All Services', href: '/services' },
  ],
  credentials: [
    {
      title: 'Bar Admissions',
      items: [
        'Colorado',
      ],
    },
    {
      title: 'Education',
      items: [
        'University of Colorado, Boulder, B.A., Theater',
        'University of Denver Sturm College of Law, J.D.',
        'University of Denver Sturm College of Law, LL.M., Taxation',
      ],
    },
    {
      title: 'Recognitions',
      items: [
        'Outstanding Graduating Law Student — Student Bar Association',
        'Graduate Tax Program Scholarship — Director\'s Award',
        'Colorado Supreme Court Pro Bono Legal Services Commitment Program (2010–2015)',
      ],
    },
    {
      title: 'Professional Involvement',
      items: [
        'Colorado Bar Association — Family Law Section',
        'Adjunct Professor, National Trial Team — DU Law School',
        'Tournament Director, The Summit Cup — DU Center for Advocacy',
        'Mentor, Professional Mentoring Program — University of Denver College of Law',
      ],
    },
  ],
};
---

<BaseLayout
  title={`${member.fullName} — KM Law`}
  description={`${member.fullName}, ${member.role} at KM Law.`}
  headerTheme="dark"
>
  <TeamMemberHero headline={member.heroHeadline} />

  <TeamMemberBio
    badge={member.badge}
    name={member.fullName}
    role={member.role}
    image={member.image}
    imageAlt={member.imageAlt}
    bio={member.bio}
    linkedin={member.linkedin}
  />

  <TeamMemberCredentials groups={member.credentials} />

  <TeamMemberPracticeAreas name={member.shortName} areas={member.practiceAreas} />

  <TeamCTA />
</BaseLayout>

<style is:global>
  /* ---- Scroll-entry animations ---- */
  [data-anim] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-anim].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-anim][data-delay="1"] { transition-delay: 0.10s; }
  [data-anim][data-delay="2"] { transition-delay: 0.20s; }
  [data-anim][data-delay="3"] { transition-delay: 0.30s; }
  [data-anim][data-delay="4"] { transition-delay: 0.40s; }
  [data-anim][data-delay="5"] { transition-delay: 0.50s; }

  /* Eyebrow transitions need to merge with data-anim */
  .member-bio__eyebrow[data-anim],
  .member-creds__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-anim] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const animEls = document.querySelectorAll('[data-anim]');
  const animObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('is-visible');
        animObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -32px 0px' });

  animEls.forEach(el => animObserver.observe(el));
</script>
