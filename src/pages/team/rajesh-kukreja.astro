---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamMemberHero from '../../components/team-member/TeamMemberHero.astro';
import TeamMemberBio from '../../components/team-member/TeamMemberBio.astro';
import TeamMemberCredentials from '../../components/team-member/TeamMemberCredentials.astro';
import TeamMemberPracticeAreas from '../../components/team-member/TeamMemberPracticeAreas.astro';
import TeamCTA from '../../components/team/TeamCTA.astro';

// ---- TEMPLATE DATA ---------------------------------------------------------
// To add a new attorney: copy this file, rename it (e.g. kyle-mcfarlane.astro),
// and replace the values in the `member` object below. The components handle
// all rendering — no markup changes needed.
const member = {
  fullName: 'Rajesh (Raj) Kukreja',
  shortName: 'Raj',
  role: 'Equity Member',
  image: '/images/Rajesh-Kureja-KM-Law-firm-bio.webp',
  imageAlt: 'Rajesh (Raj) Kukreja, Equity Member at KM Law',
  linkedin: 'https://www.linkedin.com/in/rajesh-kukreja-5b802539/',
  heroHeadline: 'Meet Raj.',
  bio: [
    "Rajesh (Raj) Kukreja is an Equity Member and Founder of Kukreja McFarlane Law and represents individuals with high-net-worth and ultra-high-net-worth marital estates through dissolution of marriage and related matters. His work routinely involves the valuation of privately held companies and business interests, real estate holdings, trusts and beneficial interests, and the analysis of executive compensation issues — including restricted stock, deferred compensation, and stock options — as well as litigation regarding the enforceability of marital agreements.",
    "Raj has extensive experience with both trial work and alternative dispute resolution, including mediation and arbitration. He represents clients throughout Colorado, including the Front Range and the state's mountain communities.",
    "Raj also holds a Certificate in Family Law Mediation from Northwestern University in Chicago, Illinois. His practice has expanded to offer mediation and arbitration services, particularly as they relate to the division of high-net-worth and ultra-high-net-worth marital estates.",
  ],
  badges: [
    {
      name: 'Best Lawyers in America',
      caption: 'Family Law, 2026',
      image: '/badges/best-lawyers-2026.svg',
    },
    {
      name: '5280 Top Lawyers',
      caption: '2026',
      image: '/badges/5280-top-lawyers-2026.svg',
    },
    {
      name: 'Martindale-Hubbell',
      caption: 'Distinguished Peer Review',
      image: '/badges/martindale-hubbell.svg',
    },
    {
      name: 'Super Lawyers',
      caption: 'Rising Star, 2009–2010',
      image: '/badges/super-lawyers.svg',
    },
  ],
  practiceAreas: [
    { title: 'High-Asset Divorce', href: '/services#high-asset-divorce' },
    { title: 'Spousal Support & Maintenance', href: '/services#spousal-support' },
    { title: 'Mediation & Arbitration', href: '/services#mediation' },
    { title: 'View All Services', href: '/services' },
  ],
  credentials: [
    {
      title: 'Bar Admissions',
      items: [
        'Colorado',
        'U.S. District Court for the District of Colorado',
        'United States Supreme Court',
      ],
    },
    {
      title: 'Education',
      items: [
        'University of Virginia, B.A., Government',
        'University of Denver Sturm College of Law, J.D.',
        'Northwestern University, Certificate in Family Law Mediation',
      ],
    },
    {
      title: 'Recognitions',
      items: [
        'Best Lawyers in America — Family Law, 2026',
        '5280 Magazine — Top Lawyers, 2026',
        'Martindale-Hubbell — Distinguished Peer Review Rating (2005–Present)',
        'Super Lawyers — Rising Star (2009–2010)',
      ],
    },
    {
      title: 'Professional Involvement',
      items: [
        'Denver Bar Association — Family Law Section',
        'Colorado Bar Association — Family Law Section',
      ],
    },
  ],
};

const description =
  "Rajesh (Raj) Kukreja, Equity Member and Founder of Kukreja McFarlane Law — leads the firm's high-asset divorce and complex litigation practice for high-net-worth Colorado clients.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://www.rkkmlaw.com/team/rajesh-kukreja#person',
  name: member.fullName,
  givenName: 'Rajesh',
  additionalName: 'Raj',
  familyName: 'Kukreja',
  jobTitle: member.role,
  image: `https://www.rkkmlaw.com${member.image}`,
  url: 'https://www.rkkmlaw.com/team/rajesh-kukreja',
  sameAs: [member.linkedin],
  worksFor: { '@id': 'https://www.rkkmlaw.com/#organization' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'University of Virginia' },
    { '@type': 'CollegeOrUniversity', name: 'University of Denver Sturm College of Law' },
    { '@type': 'CollegeOrUniversity', name: 'Northwestern University' },
  ],
  knowsAbout: [
    'High-Asset Divorce',
    'Complex Family Law Litigation',
    'Spousal Support',
    'Mediation',
    'Arbitration',
    'Marital Agreements',
    'Business Valuation in Divorce',
    'Executive Compensation Issues',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'Colorado Bar Admission',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'U.S. District Court for the District of Colorado',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'United States Supreme Court',
    },
  ],
  award: [
    'Best Lawyers in America — Family Law, 2026',
    '5280 Magazine — Top Lawyers, 2026',
    'Martindale-Hubbell — Distinguished Peer Review Rating (2005–Present)',
    'Super Lawyers — Rising Star (2009–2010)',
  ],
};
---

<BaseLayout
  title={`${member.fullName} — KM Law`}
  description={description}
  headerTheme="dark"
  schema={schema}
>
  <TeamMemberHero headline={member.heroHeadline} />

  <TeamMemberBio
    name={member.fullName}
    role={member.role}
    image={member.image}
    imageAlt={member.imageAlt}
    bio={member.bio}
    linkedin={member.linkedin}
  />

  <TeamMemberCredentials groups={member.credentials} />

  <TeamMemberPracticeAreas name={member.shortName} areas={member.practiceAreas} />

  <TeamCTA />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .member-bio__eyebrow[data-anim],
  .member-creds__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
