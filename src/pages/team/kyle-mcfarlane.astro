---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamMemberHero from '../../components/team-member/TeamMemberHero.astro';
import TeamMemberBio from '../../components/team-member/TeamMemberBio.astro';
import TeamMemberCredentials from '../../components/team-member/TeamMemberCredentials.astro';
import TeamMemberPracticeAreas from '../../components/team-member/TeamMemberPracticeAreas.astro';
import TeamCTA from '../../components/team/TeamCTA.astro';

// ---- TEMPLATE DATA ---------------------------------------------------------
// To add a new attorney: copy this file, rename it, and replace the values in
// the `member` object below. The components handle all rendering.
const member = {
  fullName: 'Kyle McFarlane',
  shortName: 'Kyle',
  role: 'Equity Member',
  image: '/images/kyle-mcfarlane-RK-Law-firm-bio.webp',
  imageAlt: 'Kyle McFarlane, Equity Member at KM Law',
  linkedin: 'https://www.linkedin.com/in/kyle-mcfarlane-54385a7a/',
  heroHeadline: 'Meet Kyle.',
  bio: [
    "Kyle McFarlane is an Equity Member and Founder of Kukreja McFarlane Law and a highly sought-after trial attorney known across Colorado for her fierce advocacy in high-stakes divorce and custody litigation. With a legal career built on deep trial experience, a commitment to excellence, and strategic precision, Kyle has become the go-to lawyer for clients navigating complex and emotionally charged family law matters — especially those involving substantial wealth, business interests, and contested parenting issues.",
    "Kyle represents clients at the highest levels of professional and financial success, including C-suite executives, attorneys, business owners, and public figures. Her practice is sharply focused on high-asset divorce cases involving intricate financial disclosures, hidden assets, business valuations, and multi-jurisdictional issues. She is equally adept in navigating high-conflict custody disputes involving allegations of abuse, psychological evaluations, interstate custody, and international child abduction.",
    "In practice, Kyle is known for her commanding presence, legal acuity, and no-nonsense approach to litigation. She thrives in contested hearings and complex settlement negotiations alike, earning the respect of judges, opposing counsel, and clients for her preparation and clarity.",
  ],
  practiceAreas: [
    { title: 'High-Asset Divorce', href: '/services#high-asset-divorce' },
    { title: 'Child Custody & Parenting', href: '/services#child-custody' },
    { title: 'Spousal Support & Maintenance', href: '/services#spousal-support' },
    { title: 'View All Services', href: '/services' },
  ],
  credentials: [
    {
      title: 'Bar Admissions',
      items: [
        'Colorado',
      ],
    },
    {
      title: 'Education',
      items: [
        'University of Denver, B.A., Sociology and Psychology',
        'University of Denver Sturm College of Law, J.D.',
      ],
    },
    {
      title: 'Recognitions',
      items: [
        'Best Lawyers in America — Family Law, 2024 & 2025',
        '5280 Magazine — Top Lawyers, Family Law/Divorce, 2025',
        'Colorado Super Lawyers, 2025; Rising Stars, 2017–2023',
        'Law Week Colorado — Barrister\'s Best, People\'s Choice for Best Family Law Lawyer, 2021',
      ],
    },
    {
      title: 'Professional Involvement',
      items: [
        'Colorado Bar Association — Family Law Section',
        'Denver Bar Association',
        'Denver Bar Association — Young Lawyers Division',
        'National Association of Legal Advocacy Educators',
      ],
    },
  ],
};

const description =
  'Kyle McFarlane, Equity Member and Founder of Kukreja McFarlane Law — trial attorney specializing in high-asset divorce, high-conflict custody, and complex family law litigation in Colorado.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://www.rkkmlaw.com/team/kyle-mcfarlane#person',
  name: member.fullName,
  givenName: 'Kyle',
  familyName: 'McFarlane',
  jobTitle: member.role,
  image: `https://www.rkkmlaw.com${member.image}`,
  url: 'https://www.rkkmlaw.com/team/kyle-mcfarlane',
  sameAs: [member.linkedin],
  worksFor: { '@id': 'https://www.rkkmlaw.com/#organization' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'University of Denver' },
    { '@type': 'CollegeOrUniversity', name: 'University of Denver Sturm College of Law' },
  ],
  knowsAbout: [
    'High-Asset Divorce',
    'High-Conflict Custody',
    'Trial Advocacy',
    'Complex Financial Disclosures',
    'Business Valuation',
    'International Child Abduction',
    'Family Law Litigation',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'Colorado Bar Admission',
    },
  ],
  award: [
    'Best Lawyers in America — Family Law, 2024 & 2025',
    '5280 Magazine — Top Lawyers, Family Law/Divorce, 2025',
    'Colorado Super Lawyers, 2025; Rising Stars, 2017–2023',
    "Law Week Colorado — Barrister's Best, People's Choice for Best Family Law Lawyer, 2021",
  ],
};
---

<BaseLayout
  title={`${member.fullName} — KM Law`}
  description={description}
  headerTheme="dark"
  schema={schema}
>
  <TeamMemberHero headline={member.heroHeadline} />

  <TeamMemberBio
    name={member.fullName}
    role={member.role}
    image={member.image}
    imageAlt={member.imageAlt}
    bio={member.bio}
    linkedin={member.linkedin}
  />

  <TeamMemberCredentials groups={member.credentials} />

  <TeamMemberPracticeAreas name={member.shortName} areas={member.practiceAreas} />

  <TeamCTA />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .member-bio__eyebrow[data-anim],
  .member-creds__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
