---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactHero from '../components/contact/ContactHero.astro';
import ContactForm from '../components/ContactForm.astro';

const description =
  'Get in touch with KM Law — schedule a confidential consultation about your family law matter. Located in Denver, Colorado.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: 'https://www.rkkmlaw.com/contact',
  name: 'Contact KM Law',
  description,
  about: { '@id': 'https://www.rkkmlaw.com/#organization' },
  mainEntity: {
    '@type': 'Organization',
    name: 'Kukreja McFarlane Law',
    email: 'info@kmlaw.com',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Denver',
      addressRegion: 'CO',
      postalCode: '80205',
      addressCountry: 'US',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      email: 'info@kmlaw.com',
      areaServed: 'US-CO',
      availableLanguage: ['English'],
    },
  },
};
---

<BaseLayout title="Contact — KM Law" description={description} headerTheme="dark" schema={schema}>
  <ContactHero />
  <ContactForm />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .contact__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
