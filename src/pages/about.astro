---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutHero from '../components/about/AboutHero.astro';
import AboutContent from '../components/about/AboutContent.astro';
import AboutQuote from '../components/about/AboutQuote.astro';
import AboutWhy from '../components/about/AboutWhy.astro';
import AboutApproach from '../components/about/AboutApproach.astro';

const description =
  'About Kukreja McFarlane Law — a Denver family law firm built for clients facing the most consequential legal matters. Decades of trial experience, exclusively focused on high-stakes family law.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: 'https://www.rkkmlaw.com/about',
  name: 'About KM Law',
  description,
  mainEntity: { '@id': 'https://www.rkkmlaw.com/#organization' },
};
---

<BaseLayout title="About — KM Law" description={description} headerTheme="dark" schema={schema}>
  <AboutHero />
  <AboutContent />
  <AboutQuote />
  <AboutWhy />
  <AboutApproach />
</BaseLayout>

<style is:global>
  /* Eyebrow transitions need to merge with data-anim. Base [data-anim] rules
     and the IntersectionObserver live in BaseLayout. */
  .about-content__eyebrow[data-anim],
  .about-why__eyebrow[data-anim],
  .about-approach__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
