---
// TeamMemberHero.astro — Simple navy hero for an individual attorney bio page.
// Mirrors the AboutHero / TeamHero pattern. Pass `headline` per attorney.
interface Props {
  headline: string;
}
const { headline } = Astro.props;
---

<section class="member-hero">
  <div class="member-hero__bottom">
    <h1 class="member-hero__headline">{headline}</h1>
    <a href="#member-bio" class="member-hero__link">
      Learn More
      <svg class="member-hero__link-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

<style>
  .member-hero {
    width: 100%;
    height: 520px;
    background: #1B3B49;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0 max(80px, calc((100vw - 1600px) / 2));
    box-sizing: border-box;
  }

  .member-hero__bottom {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    flex-grow: 1;
    padding-bottom: calc(40px + 4rem);
    max-width: 1600px;
  }

  .member-hero__headline {
    width: 690px;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 70px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .member-hero__link {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    gap: 24px;
    border-bottom: 1px solid #FFFFFF;
    width: fit-content;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    flex-shrink: 0;
    transition: color 0.3s ease;
  }

  .member-hero__link:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  .member-hero__link-arrow {
    width: 14px;
    height: 14px;
    color: #FFFFFF;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .member-hero__link:hover .member-hero__link-arrow {
    transform: translate(3px, -3px);
  }

  /* ---- Animations ---- */
  @keyframes memberHeroFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .member-hero__headline {
    animation: memberHeroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  .member-hero__link {
    animation: memberHeroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .member-hero { padding: 0 60px; }
    .member-hero__headline { font-size: 60px; width: 580px; }
  }

  @media (max-width: 1024px) {
    .member-hero { padding: 0 40px; }
    .member-hero__headline { font-size: 52px; width: 500px; }
  }

  @media (max-width: 768px) {
    .member-hero {
      padding: 0 24px;
      height: auto;
      min-height: 380px;
      justify-content: flex-end;
    }
    .member-hero__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      flex-grow: 0;
      padding-top: 24px;
      padding-bottom: 32px;
    }
    .member-hero__headline {
      font-size: 30px;
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .member-hero { padding: 0 16px; min-height: 340px; }
    .member-hero__bottom { padding-top: 20px; }
    .member-hero__headline { font-size: 26px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .member-hero__headline,
    .member-hero__link {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const learnMoreLink = document.querySelector('.member-hero__link') as HTMLAnchorElement | null;

    if (learnMoreLink) {
      learnMoreLink.addEventListener('click', function(e) {
        e.preventDefault();
        const href = learnMoreLink.getAttribute('href');
        if (!href) return;
        const targetId = href.substring(1);
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    }
  });
</script>
