---
// TeamMemberCredentials.astro — Grouped credentials grid (admissions, education,
// recognitions, etc.) for an attorney profile. Pass any number of groups.
interface CredentialGroup {
  title: string;
  items: string[];
}
interface Props {
  groups: CredentialGroup[];
}
const { groups } = Astro.props;
---

<section class="member-creds">
  <div class="member-creds__inner">

    <div class="member-creds__header">
      <span class="member-creds__eyebrow" data-anim>Credentials</span>
      <h2 class="member-creds__heading" data-anim data-delay="1">Background &amp; Recognitions.</h2>
    </div>

    <div class="member-creds__grid">
      {groups.map((group, i) => (
        <div class="member-creds__group" data-anim data-delay={String((i % 4) + 1)}>
          <h3 class="member-creds__group-title">{group.title}</h3>
          <ul class="member-creds__list">
            {group.items.map((item) => (
              <li class="member-creds__item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .member-creds {
    width: 100%;
    background: #FAFAF9;
    padding: 40px 80px 64px;
    overflow: hidden;
    box-sizing: border-box;
  }

  .member-creds__inner {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Section header — matches TeamSection header pattern */
  .member-creds__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: 40px;
    border-bottom: 1px solid #78716C;
    position: relative;
    width: 100%;
  }

  .member-creds__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716C;
    margin-bottom: 8px;
    transition: color 0.3s ease, letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .member-creds__eyebrow:hover {
    color: #1B3B49;
    letter-spacing: 0.14em;
  }

  .member-creds__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 32px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
  }

  /* ---- Grid of credential groups ---- */
  .member-creds__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px 32px;
    margin-top: 40px;
    width: 100%;
  }

  .member-creds__group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .member-creds__group-title {
    margin: 0 0 16px;
    padding-bottom: 12px;
    width: 100%;
    border-bottom: 1px solid #D6D3D1;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1B3B49;
    text-transform: capitalize;
  }

  .member-creds__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .member-creds__item {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 150%;
    letter-spacing: -0.02em;
    color: #44403C;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .member-creds { padding: 40px 60px 56px; }
    .member-creds__grid { gap: 40px 28px; }
  }

  @media (max-width: 1024px) {
    .member-creds { padding: 40px 40px 48px; }

    .member-creds__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 36px 32px;
    }
  }

  @media (max-width: 768px) {
    .member-creds { padding: 32px 24px 40px; }
    .member-creds__heading { font-size: 26px; }

    .member-creds__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 480px) {
    .member-creds { padding: 24px 16px 32px; }
    .member-creds__heading { font-size: 24px; }

    .member-creds__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
