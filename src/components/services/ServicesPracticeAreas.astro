---
// ServicesPracticeAreas.astro — Expanded practice area sections with alternating layouts
---

<!-- ================================================================
     PRACTICE AREA 1 — High-Asset Divorce (light bg, left number)
================================================================= -->
<section id="high-asset-divorce" class="spa spa--light">
  <div class="spa__inner">
    <div class="spa__header">
      <span class="spa__num" data-anim>01</span>
      <div class="spa__titles" data-anim data-delay="1">
        <h2 class="spa__heading">High-Asset<br />Divorce</h2>
        <p class="spa__lead">
          Representing individuals with significant marital estates through every stage
          of dissolution — from initial strategy through final decree. When millions are
          at stake, precision in valuation and division isn't optional.
        </p>
      </div>
    </div>
    <div class="spa__capabilities">
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Business valuations and ownership disputes</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Executive compensation and stock option division</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Real estate portfolio division</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Retirement and pension fund analysis</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Offshore and complex asset tracing</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Prenuptial and postnuptial agreement enforcement</span>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================
     PRACTICE AREA 2 — Child Custody (navy bg, reversed layout)
================================================================= -->
<section id="child-custody" class="spa spa--dark">
  <div class="spa__inner spa__inner--reversed">
    <div class="spa__header">
      <span class="spa__num" data-anim>02</span>
      <div class="spa__titles" data-anim data-delay="1">
        <h2 class="spa__heading">Child Custody<br />&amp; Parenting</h2>
        <p class="spa__lead">
          Strategic, compassionate representation in contested custody matters.
          Every parenting decision shapes a child's future — and your relationship
          with them. We fight for arrangements that protect both.
        </p>
      </div>
    </div>
    <div class="spa__capabilities">
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Initial custody determinations</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Parenting plan modifications</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Relocation disputes</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Parental alienation cases</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">High-conflict parenting coordination</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Emergency custody motions</span>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================
     PRACTICE AREA 3 — Spousal Support (light bg, left number)
================================================================= -->
<section id="spousal-support" class="spa spa--light">
  <div class="spa__inner">
    <div class="spa__header">
      <span class="spa__num" data-anim>03</span>
      <div class="spa__titles" data-anim data-delay="1">
        <h2 class="spa__heading">Spousal Support<br />&amp; Maintenance</h2>
        <p class="spa__lead">
          Skilled advocacy in the determination, modification, and enforcement
          of spousal maintenance. Whether you're the higher earner or the
          dependent spouse, the outcome shapes your financial reality for years.
        </p>
      </div>
    </div>
    <div class="spa__capabilities">
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Temporary and permanent maintenance calculations</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Modification based on changed circumstances</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Enforcement of existing orders</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">High-income earner support disputes</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Rehabilitative vs long-term maintenance strategy</span>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================
     PRACTICE AREA 4 — Mediation & ADR (navy bg, reversed layout)
================================================================= -->
<section id="mediation" class="spa spa--dark">
  <div class="spa__inner spa__inner--reversed">
    <div class="spa__header">
      <span class="spa__num" data-anim>04</span>
      <div class="spa__titles" data-anim data-delay="1">
        <h2 class="spa__heading">Mediation &amp;<br />Alternative Dispute Resolution</h2>
        <p class="spa__lead">
          Confidential, efficient resolution of family law matters outside of court.
          For clients who value privacy and control over their outcome, ADR often
          delivers better results — faster, and on your terms.
        </p>
      </div>
    </div>
    <div class="spa__capabilities">
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Mediation for high-net-worth divorce</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Collaborative divorce process</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="1">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Arbitration</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="2">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Settlement negotiation for complex estates</span>
      </div>
      <div class="spa__cap-item" data-anim data-delay="3">
        <div class="spa__cap-arrow"></div>
        <span class="spa__cap-text">Confidential resolution for public figures</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     SERVICES PRACTICE AREAS — Base
  ============================================================ */
  .spa {
    width: 100%;
    padding: 120px max(80px, calc((100vw - 1600px) / 2));
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    scroll-margin-top: 80px;
  }

  .spa__inner {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  /* ============================================================
     LIGHT VARIANT
  ============================================================ */
  .spa--light {
    background: #FAFAF9;
  }

  .spa--light .spa__num {
    color: rgba(153, 173, 140, 0.18);
  }

  .spa--light .spa__heading {
    color: #0C0A09;
  }

  .spa--light .spa__lead {
    color: #57534E;
  }

  .spa--light .spa__cap-arrow {
    background-color: #99AD8C;
  }

  .spa--light .spa__cap-arrow::after {
    border-left-color: #7A9170;
  }

  .spa--light .spa__cap-text {
    color: #44403C;
  }

  .spa--light .spa__cap-item:hover .spa__cap-arrow {
    background-color: #1B3B49;
  }

  .spa--light .spa__cap-item:hover .spa__cap-arrow::after {
    border-left-color: #1B3B49;
  }

  .spa--light .spa__cap-item:hover .spa__cap-text {
    color: #0C0A09;
  }

  /* ============================================================
     DARK VARIANT
  ============================================================ */
  .spa--dark {
    background: #1B3B49;
  }

  .spa--dark .spa__num {
    color: rgba(153, 173, 140, 0.12);
  }

  .spa--dark .spa__heading {
    color: #FAFAF9;
  }

  .spa--dark .spa__lead {
    color: rgba(216, 207, 192, 0.65);
  }

  .spa--dark .spa__cap-arrow {
    background-color: rgba(153, 173, 140, 0.5);
  }

  .spa--dark .spa__cap-arrow::after {
    border-left-color: rgba(153, 173, 140, 0.4);
  }

  .spa--dark .spa__cap-text {
    color: rgba(250, 250, 249, 0.65);
  }

  .spa--dark .spa__cap-item:hover .spa__cap-arrow {
    background-color: #99AD8C;
  }

  .spa--dark .spa__cap-item:hover .spa__cap-arrow::after {
    border-left-color: #99AD8C;
  }

  .spa--dark .spa__cap-item:hover .spa__cap-text {
    color: #FAFAF9;
  }

  /* ============================================================
     HEADER — Number + Titles
  ============================================================ */
  .spa__header {
    display: flex;
    align-items: flex-start;
    gap: 48px;
  }

  .spa__num {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 160px;
    line-height: 0.85;
    letter-spacing: -0.04em;
    flex-shrink: 0;
    user-select: none;
    transition:
      color     0.5s ease,
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .spa__titles {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 16px;
    max-width: 580px;
  }

  .spa__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 44px;
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .spa__lead {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.75;
    letter-spacing: -0.005em;
    margin: 0;
    max-width: 520px;
  }

  /* ============================================================
     REVERSED LAYOUT (areas 2, 4) — number moves right
  ============================================================ */
  .spa__inner--reversed .spa__header {
    flex-direction: row-reverse;
    text-align: right;
  }

  .spa__inner--reversed .spa__titles {
    align-items: flex-end;
  }

  .spa__inner--reversed .spa__capabilities {
    margin-left: auto;
  }

  /* ============================================================
     CAPABILITIES GRID
  ============================================================ */
  .spa__capabilities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    max-width: 920px;
  }

  .spa__cap-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 24px 20px 0;
    border-top: 1px solid rgba(120, 113, 108, 0.15);
    cursor: default;
  }

  .spa--dark .spa__cap-item {
    border-top-color: rgba(153, 173, 140, 0.12);
  }

  .spa__cap-item:nth-child(2n) {
    padding-left: 32px;
    border-left: 1px solid rgba(120, 113, 108, 0.15);
  }

  .spa--dark .spa__cap-item:nth-child(2n) {
    border-left-color: rgba(153, 173, 140, 0.12);
  }

  /* Sage arrow bullet */
  .spa__cap-arrow {
    width: 28px;
    height: 1.5px;
    flex-shrink: 0;
    transform-origin: left center;
    will-change: transform;
    position: relative;
    transition:
      background-color 0.35s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .spa__cap-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-top: 3.5px solid transparent;
    border-bottom: 3.5px solid transparent;
    border-left: 4.5px solid;
    transition: border-left-color 0.35s ease;
  }

  .spa__cap-item:hover .spa__cap-arrow {
    transform: scaleX(1.4);
  }

  .spa__cap-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
  }

  /* ============================================================
     RESPONSIVE — 1200px
  ============================================================ */
  @media (max-width: 1200px) {
    .spa {
      padding: 96px 60px;
    }

    .spa__num {
      font-size: 120px;
    }

    .spa__heading {
      font-size: 38px;
    }

    .spa__header {
      gap: 36px;
    }

    .spa__capabilities {
      max-width: 100%;
    }
  }

  /* ============================================================
     RESPONSIVE — 1024px
  ============================================================ */
  @media (max-width: 1024px) {
    .spa {
      padding: 80px 40px;
    }

    .spa__inner {
      gap: 56px;
    }

    .spa__num {
      font-size: 96px;
    }

    .spa__heading {
      font-size: 34px;
    }

    .spa__lead {
      font-size: 15px;
      max-width: 100%;
    }

    .spa__header {
      gap: 28px;
    }

    .spa__titles {
      padding-top: 8px;
    }

    .spa__capabilities {
      grid-template-columns: 1fr;
    }

    .spa__cap-item:nth-child(2n) {
      padding-left: 0;
      border-left: none;
    }
  }

  /* ============================================================
     RESPONSIVE — 768px
  ============================================================ */
  @media (max-width: 768px) {
    .spa {
      padding: 64px 24px;
    }

    .spa__inner {
      gap: 44px;
    }

    .spa__header {
      flex-direction: column;
      gap: 0;
    }

    /* Override reversed layout on mobile — always stack vertically */
    .spa__inner--reversed .spa__header {
      flex-direction: column;
      text-align: left;
    }

    .spa__inner--reversed .spa__titles {
      align-items: flex-start;
    }

    .spa__inner--reversed .spa__capabilities {
      margin-left: 0;
    }

    .spa__num {
      font-size: 64px;
      line-height: 1;
      margin-bottom: 6px;
      letter-spacing: -0.02em;
    }

    .spa__heading {
      font-size: 28px;
      line-height: 1.18;
    }

    .spa__titles {
      padding-top: 0;
      gap: 14px;
    }

    .spa__lead {
      font-size: 14.5px;
      line-height: 1.72;
    }

    /* Capability items — 44px min touch target */
    .spa__cap-item {
      padding: 14px 0;
      gap: 16px;
      min-height: 44px;
    }

    .spa__cap-text {
      font-size: 14.5px;
      line-height: 1.45;
    }

    .spa__cap-arrow {
      width: 22px;
    }
  }

  /* ============================================================
     RESPONSIVE — 480px
  ============================================================ */
  @media (max-width: 480px) {
    .spa {
      padding: 48px 20px;
    }

    .spa__inner {
      gap: 36px;
    }

    .spa__num {
      font-size: 48px;
      margin-bottom: 4px;
    }

    .spa__heading {
      font-size: 24px;
      line-height: 1.22;
    }

    .spa__titles {
      gap: 12px;
    }

    .spa__lead {
      font-size: 14px;
      line-height: 1.68;
    }

    .spa__cap-item {
      padding: 13px 0;
      gap: 14px;
      min-height: 44px;
    }

    .spa__cap-text {
      font-size: 14px;
      line-height: 1.4;
    }

    .spa__cap-arrow {
      width: 20px;
    }
  }

  /* ============================================================
     TOUCH — active states
  ============================================================ */
  @media (pointer: coarse) {
    .spa__cap-item {
      -webkit-tap-highlight-color: transparent;
    }

    .spa--light .spa__cap-item:active .spa__cap-arrow {
      background-color: #1B3B49;
      transform: scaleX(1.3);
    }

    .spa--light .spa__cap-item:active .spa__cap-text {
      color: #0C0A09;
    }

    .spa--dark .spa__cap-item:active .spa__cap-arrow {
      background-color: #99AD8C;
      transform: scaleX(1.3);
    }

    .spa--dark .spa__cap-item:active .spa__cap-text {
      color: #FAFAF9;
    }
  }

  /* ============================================================
     REDUCED MOTION
  ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .spa__cap-arrow,
    .spa__cap-text,
    .spa__num {
      transition: none;
    }
  }
</style>
