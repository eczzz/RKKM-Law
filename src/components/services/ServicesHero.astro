---
// ServicesHero.astro — Architectural navy hero with practice-area navigation index
---

<section class="sh">
  <div class="sh__inner">

    <!-- Upper content zone -->
    <div class="sh__content">
      <span class="sh__eyebrow" data-anim>Practice Areas</span>
      <h1 class="sh__headline" data-anim data-delay="2">
        Focused Exclusively on<br class="sh__br" />High-Stakes Family Law.
      </h1>
      <p class="sh__sub" data-anim data-delay="3">
        KM Law handles the full spectrum of family law matters — from complex asset
        division to high-conflict custody — with the discretion and rigor your
        situation demands.
      </p>
    </div>

    <!-- Practice-area anchor grid -->
    <div class="sh__grid">
      <a href="#high-asset-divorce" class="sh__card" data-anim data-delay="4">
        <span class="sh__card-num">01</span>
        <span class="sh__card-name">High-Asset Divorce</span>
        <svg class="sh__card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#child-custody" class="sh__card" data-anim data-delay="5">
        <span class="sh__card-num">02</span>
        <span class="sh__card-name">Child Custody &amp; Parenting</span>
        <svg class="sh__card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#spousal-support" class="sh__card" data-anim data-delay="5">
        <span class="sh__card-num">03</span>
        <span class="sh__card-name">Spousal Support &amp; Maintenance</span>
        <svg class="sh__card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#mediation" class="sh__card" data-anim data-delay="5">
        <span class="sh__card-num">04</span>
        <span class="sh__card-name">Mediation &amp; ADR</span>
        <svg class="sh__card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Decorative sage accent line -->
  <div class="sh__accent" data-anim data-delay="3"></div>
</section>

<style>
  /* ============================================================
     SERVICES HERO — full-bleed navy with index grid
  ============================================================ */
  .sh {
    width: 100%;
    min-height: 100vh;
    background: #1B3B49;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 max(80px, calc((100vw - 1600px) / 2));
    box-sizing: border-box;
  }

  .sh__inner {
    width: 100%;
    max-width: 1600px;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 64px;
  }

  /* ---- Eyebrow ---- */
  .sh__eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #99AD8C;
    margin-bottom: 32px;
  }

  /* ---- Headline ---- */
  .sh__headline {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 68px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #FAFAF9;
    max-width: 820px;
    margin-bottom: 24px;
  }

  /* ---- Subtext ---- */
  .sh__sub {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.7;
    letter-spacing: -0.005em;
    color: rgba(216, 207, 192, 0.7);
    max-width: 560px;
    margin-bottom: 72px;
  }

  /* ---- Practice-area grid ---- */
  .sh__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  /* ---- Individual card ---- */
  .sh__card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 28px 28px 32px 0;
    border-top: 1px solid rgba(153, 173, 140, 0.3);
    text-decoration: none;
    position: relative;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sh__card:first-child {
    padding-left: 0;
  }

  .sh__card + .sh__card {
    padding-left: 28px;
    border-left: 1px solid rgba(153, 173, 140, 0.12);
  }

  .sh__card:hover {
    border-top-color: #99AD8C;
  }

  /* Card number */
  .sh__card-num {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: rgba(153, 173, 140, 0.5);
    transition: color 0.3s ease;
  }

  .sh__card:hover .sh__card-num {
    color: #99AD8C;
  }

  /* Card name */
  .sh__card-name {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: rgba(250, 250, 249, 0.75);
    flex: 1;
    transition: color 0.3s ease;
  }

  .sh__card:hover .sh__card-name {
    color: #FAFAF9;
  }

  /* Card arrow */
  .sh__card-arrow {
    width: 14px;
    height: 14px;
    color: rgba(153, 173, 140, 0.4);
    flex-shrink: 0;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      color     0.3s ease;
  }

  .sh__card:hover .sh__card-arrow {
    color: #99AD8C;
    transform: translate(3px, -3px);
  }

  /* ---- Decorative accent line ---- */
  .sh__accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(153, 173, 140, 0.4) 20%,
      rgba(153, 173, 140, 0.4) 80%,
      transparent 100%
    );
  }

  /* ============================================================
     ANIMATIONS
  ============================================================ */
  .sh__eyebrow[data-anim] {
    transition:
      color          0.3s ease,
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity        0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform      0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ============================================================
     RESPONSIVE — 1200px
  ============================================================ */
  @media (max-width: 1200px) {
    .sh {
      padding: 0 60px;
    }

    .sh__headline {
      font-size: 56px;
      max-width: 680px;
    }

    .sh__card-name {
      font-size: 16px;
    }
  }

  /* ============================================================
     RESPONSIVE — 1024px
  ============================================================ */
  @media (max-width: 1024px) {
    .sh {
      padding: 0 40px;
    }

    .sh__headline {
      font-size: 48px;
      max-width: 580px;
    }

    .sh__sub {
      margin-bottom: 56px;
    }

    .sh__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .sh__card {
      padding: 24px 24px 28px 0;
    }

    .sh__card + .sh__card {
      padding-left: 24px;
    }

    /* Reset left borders for 2-col layout */
    .sh__card:nth-child(3) {
      border-left: none;
      padding-left: 0;
    }

    .sh__card:nth-child(3),
    .sh__card:nth-child(4) {
      border-top: 1px solid rgba(153, 173, 140, 0.3);
    }
  }

  /* ============================================================
     RESPONSIVE — 768px (tablet / large phone landscape)
  ============================================================ */
  @media (max-width: 768px) {
    .sh {
      padding: 0 24px;
      min-height: auto;
      padding-top: 140px;
    }

    .sh__inner {
      padding-bottom: 48px;
    }

    /* Let headline reflow naturally on narrow viewports */
    .sh__br {
      display: none;
    }

    .sh__headline {
      font-size: 34px;
      line-height: 1.14;
      max-width: 100%;
      margin-bottom: 20px;
    }

    .sh__sub {
      font-size: 15px;
      line-height: 1.75;
      max-width: 100%;
      margin-bottom: 36px;
    }

    .sh__grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .sh__card {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      padding: 18px 0;
      min-height: 56px;
    }

    .sh__card + .sh__card {
      padding-left: 0;
      border-left: none;
    }

    /* Reset 3rd-child override from 1024bp */
    .sh__card:nth-child(3) {
      padding-left: 0;
    }

    .sh__card-num {
      flex-shrink: 0;
      width: 28px;
    }

    .sh__card-name {
      font-size: 16px;
    }

    .sh__card-arrow {
      margin-left: auto;
    }
  }

  /* ============================================================
     RESPONSIVE — 480px (standard mobile)
  ============================================================ */
  @media (max-width: 480px) {
    .sh {
      padding: 0 20px;
      padding-top: 120px;
    }

    .sh__inner {
      padding-bottom: 40px;
    }

    .sh__eyebrow {
      margin-bottom: 20px;
      font-size: 10px;
      letter-spacing: 0.2em;
    }

    .sh__headline {
      font-size: 28px;
      line-height: 1.18;
      letter-spacing: -0.025em;
      margin-bottom: 16px;
    }

    .sh__sub {
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 32px;
      color: rgba(216, 207, 192, 0.75);
    }

    .sh__card {
      padding: 16px 0;
      min-height: 52px;
      gap: 14px;
    }

    .sh__card-num {
      width: 26px;
      font-size: 10px;
    }

    .sh__card-name {
      font-size: 15px;
      line-height: 1.35;
    }
  }

  /* ============================================================
     TOUCH — active states for tap feedback on touch devices
  ============================================================ */
  @media (pointer: coarse) {
    .sh__card {
      -webkit-tap-highlight-color: transparent;
    }

    .sh__card:active {
      border-top-color: #99AD8C;
    }

    .sh__card:active .sh__card-num {
      color: #99AD8C;
    }

    .sh__card:active .sh__card-name {
      color: #FAFAF9;
    }

    .sh__card:active .sh__card-arrow {
      color: #99AD8C;
      transform: translate(2px, -2px);
    }
  }

  /* ============================================================
     MOBILE ANIMATIONS — snappier timing, shorter travel
  ============================================================ */
  @media (max-width: 768px) {
    .sh__eyebrow[data-anim] {
      transition:
        color          0.2s ease,
        letter-spacing 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        opacity        0.45s cubic-bezier(0.16, 1, 0.3, 1),
        transform      0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sh__card-arrow,
    .sh__card-num,
    .sh__card-name {
      transition: none;
    }
  }
</style>

<script>
  // Smooth-scroll anchor links to sections below
  document.querySelectorAll('.sh__card').forEach(card => {
    card.addEventListener('click', (e) => {
      const href = (card as HTMLAnchorElement).getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
