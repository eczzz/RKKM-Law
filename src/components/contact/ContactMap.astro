---
// ContactMap.astro — Google Maps embed centered on downtown Denver
---

<section class="contact-map" data-anim>
  <iframe
    class="contact-map__iframe"
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12271.392706856588!2d-104.9970305!3d39.7494058!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876c78d2e79a031d%3A0x1039ddb42dc3a9ea!2sDenver%2C%20CO!5e0!3m2!1sen!2sus!4v1711828800000!5m2!1sen!2sus"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="KM Law — Denver, Colorado"
  ></iframe>
</section>

<style>
  .contact-map {
    width: 100%;
    background: #F5F5F4;
    padding: 0 80px 56px;
    position: relative;
    z-index: 1;
  }

  .contact-map__iframe {
    display: block;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    height: 360px;
    border: none;
    border-radius: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .contact-map { padding: 0 60px 48px; }
  }

  @media (max-width: 1024px) {
    .contact-map { padding: 0 40px 48px; }
    .contact-map__iframe { height: 300px; }
  }

  @media (max-width: 768px) {
    .contact-map { padding: 0 24px 40px; }
    .contact-map__iframe { height: 260px; }
  }

  @media (max-width: 480px) {
    .contact-map { padding: 0 16px 32px; }
    .contact-map__iframe { height: 220px; }
  }
</style>
