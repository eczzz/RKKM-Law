---
// TeamCTA.astro — Navy CTA banner for the Team page
---

<section class="team-cta">
  <div class="team-cta__inner">

    <h2 class="team-cta__headline" data-anim>
      Ready to get started? Your consultation begins with a conversation.
    </h2>

    <p class="team-cta__tagline" data-anim data-delay="1">
      RKKM Law represents clients who cannot afford the wrong outcome. If you've been referred to us, we're ready to listen.
    </p>

    <a href="/contact" class="team-cta__link" data-anim data-delay="2">
      Schedule a Consultation
      <svg class="team-cta__link-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>

  </div>
</section>

<style>
  .team-cta {
    width: 100%;
    background: #1C2E4A;
    padding: 0 80px 56px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .team-cta__inner {
    width: 100%;
    max-width: 1280px;
    height: 536px;
    margin: 0 auto;
    position: relative;
  }

  .team-cta__headline {
    position: absolute;
    top: 55px;
    left: 0;
    width: 869px;
    margin: 0;
    padding: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 46px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #FAFAF9;
  }

  .team-cta__tagline {
    position: absolute;
    top: 368px;
    left: 0;
    width: 280px;
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 150%;
    letter-spacing: -0.03em;
    color: rgba(250, 250, 249, 0.8);
  }

  .team-cta__link {
    position: absolute;
    top: 393px;
    left: 853px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    gap: 24px;
    border-bottom: 1px solid #F0F0F0;
    width: fit-content;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #F0F0F0;
    transition: color 0.3s ease;
  }

  .team-cta__link:hover {
    color: rgba(240, 240, 240, 0.7);
  }

  .team-cta__link-arrow {
    width: 14px;
    height: 14px;
    color: #F0F0F0;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-cta__link:hover .team-cta__link-arrow {
    transform: translate(3px, -3px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .team-cta { padding: 0 60px 56px; }
    .team-cta__headline { width: 700px; font-size: 40px; }
    .team-cta__link { left: auto; right: 0; }
  }

  @media (max-width: 1024px) {
    .team-cta { padding: 0 40px 48px; }

    .team-cta__inner {
      height: auto;
      position: static;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
      padding-top: 64px;
    }

    .team-cta__headline {
      position: static;
      width: 100%;
      font-size: 36px;
    }

    .team-cta__tagline {
      position: static;
      width: 100%;
    }

    .team-cta__link {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .team-cta { padding: 0 24px 40px; }
    .team-cta__headline { font-size: 30px; }

    .team-cta__inner {
      padding-top: 48px;
      gap: 24px;
    }


  }

  @media (max-width: 480px) {
    .team-cta { padding: 0 16px 32px; }
    .team-cta__headline { font-size: 24px; }
    .team-cta__inner { padding-top: 40px; }


  }
</style>
