---
// TeamSection.astro — "Our Team" grid section with subsections for each tier.
---

<section class="team" id="team-content">
  <div class="team__inner">

    <div class="team__header">
      <span class="team__eyebrow" data-anim>Our Team</span>
      <h2 class="team__heading" data-anim data-delay="1">The People<br />Behind Your Case.</h2>
    </div>

    <!-- ── Subsection: Equity Members ──────────────────────────── -->
    <div class="team__subheader" data-anim>
      <span class="team__subeyebrow">Equity Members</span>
    </div>
    <div class="team__row team__row--large">

      <a href="/team/rajesh-kukreja" class="team__card" data-anim>
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/Rajesh-Kureja-KM-Law-firm-bio.webp" alt="Rajesh (Raj) Kukreja" />
        </div>
        <div class="team__info">
          <span class="team__name">Rajesh (Raj) Kukreja</span>
          <span class="team__title--role">Equity Member</span>
          <span class="team__title--specialty">High-Asset Divorce & Complex Litigation</span>
        </div>
      </a>

      <a href="/team/kyle-mcfarlane" class="team__card" data-anim data-delay="1">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/kyle-mcfarlane-RK-Law-firm-bio.webp" alt="Kyle McFarlane" />
        </div>
        <div class="team__info">
          <span class="team__name">Kyle McFarlane</span>
          <span class="team__title--role">Equity Member</span>
          <span class="team__title--specialty">Trial Advocacy & High-Conflict Family Law</span>
        </div>
      </a>

    </div>

    <!-- ── Subsection: Non-Equity Members ──────────────────────── -->
    <div class="team__subheader" data-anim>
      <span class="team__subeyebrow">Non-Equity Members</span>
    </div>
    <div class="team__row team__row--large">

      <a href="/team/non-equity-members#kevin-keyes" class="team__card" data-anim>
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/kevin-keyes-km-law-firm-bio.webp" alt="Kevin Keyes" />
        </div>
        <div class="team__info">
          <span class="team__name">Kevin Keyes</span>
          <span class="team__title--role">Non-Equity Member</span>
          <span class="team__title--specialty">Family Law & Alternative Dispute Resolution</span>
        </div>
      </a>

      <a href="/team/non-equity-members#heather-sanders" class="team__card" data-anim data-delay="1">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/heather-sanders-KM-law-firm-bio.webp" alt="Heather Sanders" />
        </div>
        <div class="team__info">
          <span class="team__name">Heather Sanders</span>
          <span class="team__title--role">Non-Equity Member</span>
          <span class="team__title--specialty">Family Law</span>
        </div>
      </a>

    </div>

    <!-- ── Subsection: Associate Attorneys ─────────────────────── -->
    <div class="team__subheader" data-anim>
      <span class="team__subeyebrow">Associate Attorneys</span>
    </div>
    <div class="team__row team__row--small">

      <a href="/team/associate-attorneys#allison-derschang" class="team__card" data-anim>
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/allison-derschang-rk-law-firm-bio.webp" alt="Allison Derschang" />
        </div>
        <div class="team__info team__info--small">
          <span class="team__name">Allison Derschang</span>
          <span class="team__title--staff">Associate Attorney</span>
        </div>
      </a>

      <a href="/team/associate-attorneys#patricia-martin" class="team__card" data-anim data-delay="1">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/patricia-martin-rk-law-firm-bio.webp" alt="Patricia Martin" />
        </div>
        <div class="team__info team__info--small">
          <span class="team__name">Patricia Martin</span>
          <span class="team__title--staff">Associate Attorney</span>
        </div>
      </a>

      <a href="/team/associate-attorneys#kayla-quinn" class="team__card" data-anim data-delay="2">
        <div class="team__photo-wrap">
          <img class="team__photo" src="/images/kayla-quinn-RK-law-firm-bio.webp" alt="Kayla Quinn" />
        </div>
        <div class="team__info team__info--small">
          <span class="team__name">Kayla Quinn</span>
          <span class="team__title--staff">Associate Attorney</span>
        </div>
      </a>

    </div>

    <!-- ── Subsection: Paralegals & Staff ──────────────────────── -->
    <div class="team__subheader" data-anim>
      <span class="team__subeyebrow">Paralegals &amp; Staff</span>
    </div>
    <ul class="team__roster">
      <li class="team__roster-row" data-anim>
        <span class="team__roster-dash" aria-hidden="true"></span>
        <span class="team__roster-name">Emma Voiles</span>
        <span class="team__roster-role">Paralegal</span>
      </li>
      <li class="team__roster-row" data-anim data-delay="1">
        <span class="team__roster-dash" aria-hidden="true"></span>
        <span class="team__roster-name">Summer Sisneros</span>
        <span class="team__roster-role">Paralegal</span>
      </li>
      <li class="team__roster-row" data-anim data-delay="2">
        <span class="team__roster-dash" aria-hidden="true"></span>
        <span class="team__roster-name">Annemarie Landis</span>
        <span class="team__roster-role">Paralegal</span>
      </li>
      <li class="team__roster-row" data-anim data-delay="3">
        <span class="team__roster-dash" aria-hidden="true"></span>
        <span class="team__roster-name">Maddie Maynor</span>
        <span class="team__roster-role">Law Clerk</span>
      </li>
      <li class="team__roster-row" data-anim data-delay="4">
        <span class="team__roster-dash" aria-hidden="true"></span>
        <span class="team__roster-name">Jillian Allmain</span>
        <span class="team__roster-role">Receptionist &amp; Administrative Assistant</span>
      </li>
    </ul>

  </div>
</section>

<style>
  .team {
    width: 100%;
    background: #FAFAF9;
    padding: 40px 80px;
    overflow: hidden;
  }

  .team__inner {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0px;
  }

  /* Section header */
  .team__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: 40px;
    border-bottom: 1px solid #78716C;
    position: relative;
    width: 100%;
  }

  .team__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716C;
    margin-bottom: 8px;
    transition: color 0.3s ease, letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team__eyebrow:hover {
    color: #1B3B49;
    letter-spacing: 0.14em;
  }

  .team__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 32px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
  }

  /* Subsection header (between groups) */
  .team__subheader {
    margin-top: 48px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(120, 113, 108, 0.25);
    width: 100%;
  }

  .team__subeyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12px;
    line-height: 18px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1B3B49;
  }

  /* Large-card row */
  .team__row--large {
    display: flex;
    flex-direction: row;
    gap: 18px;
    margin-top: 24px;
    width: 100%;
  }

  /* Small-card row */
  .team__row--small {
    display: flex;
    flex-direction: row;
    gap: 16px;
    margin-top: 24px;
    width: 100%;
  }

  /* Shared card styles */
  .team__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: 1;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  /* ─── Paralegals & Staff roster ────────────────────────────
     Text-only directory, no photo cards. Sage dash + name on
     the left, role aligned right, separated by thin border lines. */
  .team__roster {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    width: 100%;
    border-top: 1px solid rgba(120, 113, 108, 0.18);
  }

  .team__roster-row {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 22px 4px;
    border-bottom: 1px solid rgba(120, 113, 108, 0.18);
  }

  /* Sage dash + arrow tip — matches the About Us bullets on the home page */
  .team__roster-dash {
    width: 40px;
    height: 2px;
    flex-shrink: 0;
    position: relative;
    background-color: #597B60;
    transform-origin: left center;
    will-change: transform;
    transition:
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.35s ease;
  }

  .team__roster-dash::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid #597B60;
    transition: border-left-color 0.35s ease;
  }

  .team__roster-row:hover .team__roster-dash {
    transform: scaleX(1.38);
    background-color: #1B3B49;
  }

  .team__roster-row:hover .team__roster-dash::after {
    border-left-color: #1B3B49;
  }

  .team__roster-name {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 18px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #0C0A09;
    flex: 1;
    transition: color 0.35s ease;
  }

  .team__roster-row:hover .team__roster-name {
    color: #1B3B49;
  }

  .team__roster-role {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 130%;
    letter-spacing: -0.02em;
    color: #57534E;
    text-align: right;
  }

  .team__photo-wrap {
    width: 100%;
    overflow: hidden;
  }

  .team__photo {
    width: 100%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
    display: block;
    transition: transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Large row: ~1:1 */
  .team__row--large .team__photo {
    aspect-ratio: 1 / 1;
  }

  /* Small row: ~3:4 */
  .team__row--small .team__photo {
    aspect-ratio: 3 / 4;
  }

  .team__card:hover .team__photo {
    transform: scale(1.04);
  }

  /* Info block — large cards */
  .team__info {
    display: flex;
    flex-direction: column;
    padding: 16px 0px;
    gap: 4px;
    width: 100%;
  }

  /* Info block — small cards */
  .team__info--small {
    gap: 2px;
  }

  .team__name {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #0C0A09;
    transition: color 0.3s ease;
  }

  .team__card:hover .team__name {
    color: #1B3B49;
  }

  /* Partner role */
  .team__title--role {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #0C0A09;
  }

  /* Partner specialty */
  .team__title--specialty {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 130%;
    letter-spacing: -0.03em;
    color: #57534E;
  }

  /* Staff title */
  .team__title--staff {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #57534E;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .team { padding: 40px 60px; }
  }

  @media (max-width: 1024px) {
    .team { padding: 40px 40px; }

    .team__row--small {
      flex-wrap: wrap;
    }

    .team__row--small .team__card {
      flex: 0 0 calc(50% - 8px);
      min-width: 0;
    }
  }

  @media (max-width: 768px) {
    .team { padding: 32px 24px; }

    .team__row--large {
      flex-direction: column;
    }

    .team__row--large .team__card {
      flex: none;
      width: 100%;
    }

    .team__heading {
      font-size: 26px;
    }

    /* Roster collapses to stacked: dash + name on top, role below indented */
    .team__roster-row {
      flex-wrap: wrap;
      gap: 12px 20px;
      padding: 18px 4px;
    }

    .team__roster-name {
      flex: 1 1 auto;
      font-size: 17px;
    }

    .team__roster-role {
      flex: 0 0 100%;
      text-align: left;
      padding-left: 60px;
      margin-top: -4px;
    }
  }

  @media (max-width: 480px) {
    .team { padding: 24px 16px; }

    .team__row--large,
    .team__row--small {
      flex-direction: column;
      gap: 24px;
    }

    .team__row--large .team__card,
    .team__row--small .team__card {
      flex: none;
      width: 100%;
    }

    .team__heading {
      font-size: 24px;
    }
  }
</style>
