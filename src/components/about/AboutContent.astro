---
// AboutContent.astro — About Us body section with copy + image + CTA
---

<section class="about-content" id="about-content">
  <div class="about-content__inner">

    <!-- Left column: eyebrow + body copy -->
    <div class="about-content__left">
      <span class="about-content__eyebrow" data-anim>About Us</span>
      <div class="about-content__copy" data-anim data-delay="1">
        <p class="about-content__body">
          We founded Kukreja McFarlane Law on a simple belief: that clients navigating
          the most significant legal and financial transitions of their lives deserve
          counsel that matches the complexity of what they're facing.
        </p>
        <p class="about-content__body">
          Our attorneys have represented executives, business owners, and high-net-worth
          individuals through the state's most intricate dissolution and custody matters.
          We are trial-ready when needed, skilled negotiators when that serves you better,
          and uncompromising in our commitment to the outcomes our clients deserve.
        </p>
      </div>
    </div>

    <!-- Right column: image + CTA link -->
    <div class="about-content__right">
      <div class="about-content__image-wrap">
        <div class="about-content__image" data-anim></div>
      </div>
      <a href="/contact" class="about-content__cta" data-anim data-delay="1">
        Schedule A Consultation
        <svg class="about-content__cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .about-content {
    width: 100%;
    background: #F5F5F4;
    padding: 40px 80px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .about-content__inner {
    width: 100%;
    max-width: 1280px;
    height: 675px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    position: relative;
  }

  /* ---- Left column ---- */
  .about-content__left {
    width: 483px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 13px;
    flex-shrink: 0;
  }

  .about-content__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716C;
    transition: color 0.3s ease, letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-content__eyebrow:hover {
    color: #1C2E4A;
    letter-spacing: 0.14em;
  }

  .about-content__copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 483px;
  }

  .about-content__body {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 140%;
    letter-spacing: -0.03em;
    color: #0C0A09;
  }

  /* ---- Right column ---- */
  .about-content__right {
    position: absolute;
    left: 623px;
    top: 0;
    width: 657px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
  }

  .about-content__image-wrap {
    width: 655px;
    height: 392px;
    overflow: hidden;
    margin-top: 3rem;
  }

  .about-content__image {
    width: 100%;
    height: 100%;
    background: url('/About-RKKM-Law-firm-v2.webp') center / cover no-repeat;
    background-color: #D6D3D1;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-content__image-wrap:hover .about-content__image {
    transform: scale(1.04);
  }

  .about-content__cta {
    margin-top: 81px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    gap: 24px;
    border-bottom: 1px solid #1C2E4A;
    width: fit-content;
    align-self: flex-start;
    margin-left: 24px;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
    transition: color 0.3s ease;
  }

  .about-content__cta:hover {
    color: #1C2E4A;
  }

  .about-content__cta-arrow {
    width: 14px;
    height: 14px;
    color: #1C2E4A;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-content__cta:hover .about-content__cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1400px) {
    .about-content { padding: 40px 60px; }

    .about-content__left { width: 420px; }
    .about-content__copy { width: 420px; }
    .about-content__body { font-size: 20px; }

    .about-content__right { left: 500px; width: auto; right: 0; }
    .about-content__image-wrap { width: 100%; }
  }

  @media (max-width: 1024px) {
    .about-content { padding: 40px 40px; }

    .about-content__inner {
      flex-direction: column;
      height: auto;
      gap: 40px;
    }

    .about-content__left { width: 100%; }
    .about-content__copy { width: 100%; }
    .about-content__body { font-size: 20px; }

    .about-content__right {
      position: static;
      width: 100%;
      align-items: flex-start;
    }

    .about-content__image-wrap {
      width: 100%;
      height: 340px;
    }

    .about-content__cta {
      margin-top: 32px;
      align-self: flex-start;
    }
  }

  @media (max-width: 768px) {
    .about-content { padding: 32px 24px; }
    .about-content__body { font-size: 18px; }
    .about-content__image-wrap { height: 280px; }
  }

  @media (max-width: 480px) {
    .about-content { padding: 24px 16px; }
    .about-content__body { font-size: 16px; }
    .about-content__image-wrap { height: 220px; }
    .about-content__cta { margin-top: 24px; }
  }
</style>
