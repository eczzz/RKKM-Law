---
// AboutQuote.astro — Navy quote banner for the About page
---

<section class="about-quote">
  <div class="about-quote__inner">

    <div class="about-quote__left">
      <blockquote class="about-quote__text" data-anim>
        "People might discount the need for a real trial attorney in family law —
        but the reality is that most people's first and only experience with the
        justice system is through family law. The need for a skilled trial attorney
        in your family law case is just as important as any other area of the law."
      </blockquote>

      <span class="about-quote__attribution" data-anim data-delay="1">
        — Kyle McFarlane, Equity Member
      </span>
    </div>

    <div class="about-quote__right" data-anim data-delay="2">
      <p class="about-quote__tagline">
        KM Law represents clients who
        cannot afford the wrong outcome.
      </p>

      <a href="/contact" class="about-quote__cta">
        Schedule A Consultation
        <svg class="about-quote__cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .about-quote {
    width: 100%;
    background: #1B3B49;
    padding: 80px 80px;
    box-sizing: border-box;
  }

  .about-quote__inner {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    gap: 80px;
    align-items: stretch;
  }

  /* Left: quote + byline */
  .about-quote__left {
    flex: 3;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about-quote__text {
    margin: 0;
    padding: 0;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: 26px;
    line-height: 150%;
    letter-spacing: -0.02em;
    color: #FAFAF9;
  }

  .about-quote__attribution {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 140%;
    letter-spacing: -0.02em;
    color: rgba(250, 250, 249, 0.7);
  }

  /* Right: tagline + CTA */
  .about-quote__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 32px;
  }

  .about-quote__tagline {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 160%;
    letter-spacing: -0.02em;
    color: rgba(250, 250, 249, 0.6);
    text-align: right;
  }

  .about-quote__cta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    margin-top: auto;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(250, 250, 249, 0.4);
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #FAFAF9;
    white-space: nowrap;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .about-quote__cta:hover {
    color: rgba(250, 250, 249, 0.7);
    border-color: rgba(250, 250, 249, 0.2);
  }

  .about-quote__cta-arrow {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-quote__cta:hover .about-quote__cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1200px) {
    .about-quote { padding: 64px 60px; }
    .about-quote__text { font-size: 24px; }
  }

  @media (max-width: 1024px) {
    .about-quote { padding: 56px 40px; }
    .about-quote__inner { gap: 48px; }
    .about-quote__text { font-size: 22px; }
  }

  @media (max-width: 768px) {
    .about-quote { padding: 48px 24px; }
    .about-quote__inner {
      flex-direction: column;
      gap: 24px;
      align-items: flex-start;
    }
    .about-quote__text { font-size: 20px; }
    .about-quote__right {
      align-items: flex-start;
      gap: 24px;
      margin-top: 8px;
    }
    .about-quote__tagline { text-align: left; }
    .about-quote__cta { margin-top: 0; }
  }

  @media (max-width: 480px) {
    .about-quote { padding: 40px 16px; }
    .about-quote__text { font-size: 18px; }
    .about-quote__attribution { font-size: 14px; }
    .about-quote__tagline { font-size: 14px; }
  }
</style>
