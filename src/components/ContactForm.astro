---
// ContactForm.astro — Reusable contact form + info panel section
---

<section class="contact">
  <div class="contact__inner">

    <!-- Left column: form -->
    <div class="contact__left">

      <div class="contact__header">
        <span class="contact__eyebrow" data-anim>Get In Touch</span>
        <h2 class="contact__heading" data-anim data-delay="1">Contact Us</h2>
        <p class="contact__subtext" data-anim data-delay="2">Your matter is confidential. Reach out to schedule a consultation and one of our attorneys will be in touch shortly.</p>
      </div>

      <div class="contact__fields" data-anim data-delay="3">
        <input class="contact__input" type="text" placeholder="Full Name*" />
        <input class="contact__input" type="text" placeholder="Phone Number*" />
        <input class="contact__input" type="email" placeholder="Email Address*" />
        <textarea class="contact__input contact__textarea" placeholder="Message*" rows="5"></textarea>
      </div>

      <div class="contact__submit" data-anim data-delay="4">
        Request A Consultation
        <svg class="contact__submit-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>

    </div>



  </div>
</section>

<style>
  .contact {
    width: 100%;
    background: #F5F5F4;
    padding: 56px 80px;
    position: relative;
    z-index: 1;
  }

  .contact__inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 140px;
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
  }

  /* Left column */
  .contact__left {
    flex: 1;
    min-width: 0;
    max-width: 540px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0px;
  }

  .contact__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .contact__eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 21px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716C;
  }
  .contact__eyebrow:hover { color: #1B3B49; letter-spacing: 0.14em; }

  .contact__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 32px;
    line-height: 110%;
    letter-spacing: -0.03em;
    color: #1C1917;
  }

  .contact__subtext {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 28px;
    color: #57534E;
  }

  .contact__fields {
    display: flex;
    flex-direction: column;
    gap: 0px;
    width: 400px;
    margin-bottom: 40px;
  }

  .contact__input {
    display: block;
    width: 100%;
    padding: 22px 0px;
    border: none;
    border-bottom: 1px solid #D6D6D6;
    background: transparent;
    outline: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 18px;
    letter-spacing: 0.02em;
    color: #1C1917;
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
    border-bottom: 1px solid #D6D6D6;
  }

  .contact__input::placeholder {
    color: #828282;
  }

  .contact__submit {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding: 0px 16px;
    border-bottom: 1px solid #1B3B49;
    width: fit-content;
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #1C1917;
    transition: color 0.3s ease;
  }

  .contact__submit:hover { color: #1B3B49; }

  .contact__submit-arrow {
    width: 14px;
    height: 14px;
    color: #1B3B49;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact__submit:hover .contact__submit-arrow { transform: translate(3px, -3px); }

  .contact__input { transition: border-bottom-color 0.3s ease; }
  .contact__input:focus { border-bottom-color: #1B3B49; }



  /* ---- Responsive ---- */
  @media (max-width: 1440px) {
    .contact__inner { gap: 80px; }
    .contact__fields { width: 100%; }
  }

  @media (max-width: 1200px) {
    .contact { padding: 48px 60px; }
    .contact__inner { gap: 56px; }
    .contact__heading { font-size: 28px; }
  }

  @media (max-width: 1024px) {
    .contact { padding: 48px 40px; }
    .contact__left { width: 100%; flex: none; max-width: none; }
    .contact__fields { width: 100%; }
  }

  @media (max-width: 768px) {
    .contact { padding: 40px 24px; }
    .contact__heading { font-size: 24px; }
  }

  @media (max-width: 480px) {
    .contact { padding: 32px 16px; }
  }
</style>
