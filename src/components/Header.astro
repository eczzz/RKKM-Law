---
// Header.astro — Sticky pill header + full-screen mobile menu for KM Law
import HamburgerMenu from './HamburgerMenu.astro';

interface Props {
  theme?: 'light' | 'dark';
}

const { theme = 'light' } = Astro.props;
---

<header class={`header${theme === 'dark' ? ' header--dark' : ''}`}>

  <!-- ── Top bar (desktop + mobile) ─────────────────── -->
  <div class="header__bar">

    <a href="/" class="header__logo-link">
      <img src="/images/Main-Logo-KM-Law.webp" alt="KM Law" class="header__logo" />
    </a>

    <a href="/" class="header__mobile-logo-link header__mobile-logo-link--show-mobile-only">
      <img src="/images/Main-Logo-KM-Law.webp" alt="KM Law" class="header__mobile-logo" />
    </a>

    <nav class="header__nav">
      <a href="/" class="header__nav-link">Home</a>
      <a href="/about" class="header__nav-link">About</a>
      <div class="header__nav-item header__nav-item--has-dropdown">
        <a href="/team" class="header__nav-link header__nav-link--parent">
          Our Team
          <svg class="header__nav-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="header__dropdown" role="menu">
          <a href="/team/rajesh-kukreja" class="header__dropdown-link" role="menuitem">Rajesh (Raj) Kukreja</a>
          <a href="/team/kyle-mcfarlane" class="header__dropdown-link" role="menuitem">Kyle McFarlane</a>
          <a href="/team/kevin-keyes" class="header__dropdown-link" role="menuitem">Kevin Keyes</a>
        </div>
      </div>
      <a href="/services" class="header__nav-link">Services</a>
      <a href="/client-page" class="header__nav-link">Client Page</a>
      <a href="/contact" class="header__nav-link">Contact</a>
    </nav>

    <a href="/contact" class="header__cta">
      Schedule a Consultation
      <svg class="header__cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>

    <div class="header__hamburger-wrap">
      <HamburgerMenu size="64px" color="transparent" id="header-hamburger" />
    </div>

  </div>

  <!-- ── Full-screen mobile menu ─────────────────────── -->
  <div class="header__menu" aria-hidden="true">

    <!-- Logo in the top-left of the menu -->
    <a href="/" class="header__menu-logo">
      <img src="/images/Main-Logo-KM-Law.webp" alt="KM Law" class="header__menu-logo-img" />
    </a>

    <!-- In-menu hamburger: mirrors the bar hamburger and acts as the close trigger -->
    <div class="header__menu-hamburger">
      <HamburgerMenu size="64px" color="transparent" id="header-hamburger-close" />
    </div>

    <nav class="header__menu-nav">
      <a href="/" class="header__menu-link">
        <span class="header__menu-num">01</span>
        <span class="header__menu-text">Home</span>
      </a>
      <a href="/about" class="header__menu-link">
        <span class="header__menu-num">02</span>
        <span class="header__menu-text">About</span>
      </a>
      <a href="/team" class="header__menu-link header__menu-link--has-sub">
        <span class="header__menu-num">03</span>
        <span class="header__menu-text">Our Team</span>
      </a>
      <div class="header__menu-sublinks">
        <a href="/team/rajesh-kukreja" class="header__menu-sublink">
          <span class="header__menu-sublink-dash" aria-hidden="true"></span>
          <span class="header__menu-sublink-text">Rajesh (Raj) Kukreja</span>
        </a>
        <a href="/team/kyle-mcfarlane" class="header__menu-sublink">
          <span class="header__menu-sublink-dash" aria-hidden="true"></span>
          <span class="header__menu-sublink-text">Kyle McFarlane</span>
        </a>
        <a href="/team/kevin-keyes" class="header__menu-sublink">
          <span class="header__menu-sublink-dash" aria-hidden="true"></span>
          <span class="header__menu-sublink-text">Kevin Keyes</span>
        </a>
      </div>
      <a href="/services" class="header__menu-link">
        <span class="header__menu-num">04</span>
        <span class="header__menu-text">Services</span>
      </a>
      <a href="/client-page" class="header__menu-link">
        <span class="header__menu-num">05</span>
        <span class="header__menu-text">Client Page</span>
      </a>
      <a href="/contact" class="header__menu-link">
        <span class="header__menu-num">06</span>
        <span class="header__menu-text">Contact</span>
      </a>
    </nav>

    <div class="header__menu-footer">
      <p class="header__menu-tagline">
        Trusted Counsel for Life's<br />Most Complex Family Law Matters.
      </p>
      <a href="/contact" class="header__menu-cta">
        Schedule a Consultation
        <svg class="header__menu-cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </div>

</header>

<style>
  /* ============================================================
     BASE BAR — fixed, transparent at top
  ============================================================ */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    padding: 32px 80px 0;
    transition: padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .header__bar {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    position: relative;
    border-radius: 0;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
    padding: 0;
    transition:
      background    0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-radius 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow    0.4s cubic-bezier(0.16, 1, 0.3, 1),
      padding       0.4s cubic-bezier(0.16, 1, 0.3, 1),
      max-width     0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: auto;
  }

  /* ============================================================
     SCROLLED — navy frosted pill
  ============================================================ */
  .header--scrolled {
    padding: 16px 40px;
  }

  .header--scrolled .header__bar {
    max-width: 1600px;
    background: rgba(27, 59, 73, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 0;
    padding: 10px 24px;
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.08);
  }

  /* ============================================================
     LOGO
  ============================================================ */
  .header__logo-link {
    opacity: 0;
    pointer-events: none;
    width: 0;
    margin-right: 0;
    overflow: hidden;
    flex-shrink: 0;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                width 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                margin-right 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--scrolled .header__logo-link {
    opacity: 1;
    pointer-events: auto;
    width: 80px;
    margin-right: 24px;
  }

  .header__logo {
    height: 24px;
    width: 80px;
    object-fit: contain;
    object-position: left center;
    display: block;
    flex-shrink: 0;
  }

  /* ============================================================
     MOBILE-ONLY LOGO (before scroll)
  ============================================================ */
  .header__mobile-logo-link {
    display: none;
    flex-shrink: 0;
    margin-right: auto;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__mobile-logo-link--hidden {
    display: none !important;
  }

  .header__mobile-logo-link--show-mobile-only {
    display: none;
  }

  @media (max-width: 768px) {
    .header__mobile-logo-link--show-mobile-only {
      display: flex;
    }
  }

  .header--scrolled .header__mobile-logo-link {
    opacity: 0;
    pointer-events: none;
  }

  .header__mobile-logo {
    height: 32px;
    width: auto;
    object-fit: contain;
    display: block;
    mix-blend-mode: darken;
  }

  /* ============================================================
     DESKTOP NAV LINKS
  ============================================================ */
  .header__nav {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 32px;
    list-style: none;
    flex: 1;
    justify-content: flex-start;
  }

  .header__nav-link {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: rgba(250, 250, 249, 0.7);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--scrolled .header__nav-link {
    color: rgba(250, 250, 249, 0.7);
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--stone-50);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.4s ease;
  }

  .header--scrolled .header__nav-link::after {
    background: var(--stone-50);
  }

  .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header--scrolled .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header__nav-link:hover::after {
    transform: scaleX(1);
  }

  .header__nav > *:nth-child(1) { animation: hdrFadeDown 0.5s ease 0.08s both; }
  .header__nav > *:nth-child(2) { animation: hdrFadeDown 0.5s ease 0.14s both; }
  .header__nav > *:nth-child(3) { animation: hdrFadeDown 0.5s ease 0.20s both; }
  .header__nav > *:nth-child(4) { animation: hdrFadeDown 0.5s ease 0.26s both; }
  .header__nav > *:nth-child(5) { animation: hdrFadeDown 0.5s ease 0.32s both; }
  .header__nav > *:nth-child(6) { animation: hdrFadeDown 0.5s ease 0.38s both; }

  /* ============================================================
     DROPDOWN — Our Team child menu (desktop)
  ============================================================ */
  .header__nav-item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header__nav-link--parent {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .header__nav-caret {
    width: 10px;
    height: 6px;
    flex-shrink: 0;
    color: currentColor;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__nav-item--has-dropdown:hover .header__nav-caret,
  .header__nav-item--has-dropdown:focus-within .header__nav-caret {
    transform: rotate(180deg);
  }

  .header__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translate(-50%, 8px);
    min-width: 240px;
    padding: 12px 4px;
    background: rgba(27, 59, 73, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity   0.3s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 12px;
  }

  /* Invisible bridge so the dropdown doesn't close when moving the cursor across the gap */
  .header__nav-item--has-dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 24px;
    pointer-events: none;
  }

  .header__nav-item--has-dropdown:hover::after,
  .header__nav-item--has-dropdown:focus-within::after {
    pointer-events: auto;
  }

  .header__nav-item--has-dropdown:hover .header__dropdown,
  .header__nav-item--has-dropdown:focus-within .header__dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .header__dropdown-link {
    display: block;
    padding: 10px 20px;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: rgba(250, 250, 249, 0.75);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.3s ease, background 0.3s ease;
  }

  .header__dropdown-link:hover {
    color: #FAFAF9;
    background: rgba(250, 250, 249, 0.06);
  }

  /* ============================================================
     CTA BUTTON
  ============================================================ */
  .header__cta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding: 0 16px;
    border-bottom: 1px solid #1C1917;
    width: fit-content;
    background: none;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: hdrFadeDown 0.5s ease 0.38s both;
    flex-shrink: 0;
    border-bottom-color: #FFFFFF;
  }

  .header--scrolled .header__cta {
    color: var(--stone-50);
    border-bottom-color: var(--stone-50);
  }

  .header__cta:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .header--scrolled .header__cta:hover {
    color: rgba(250, 250, 249, 0.75);
  }

  .header__cta-arrow {
    width: 14px;
    height: 14px;
    color: #FFFFFF;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--scrolled .header__cta-arrow {
    color: var(--stone-50);
  }

  .header__cta:hover .header__cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ============================================================
     DARK THEME — light text (matches scrolled state) site-wide
  ============================================================ */
  .header--dark .header__nav-link {
    color: rgba(250, 250, 249, 0.7);
  }

  .header--dark .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header--dark .header__nav-link::after {
    background: var(--stone-50);
  }

  .header--dark .header__cta {
    color: #FFFFFF;
    border-bottom-color: #FFFFFF;
  }

  .header--dark .header__cta:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .header--dark .header__cta-arrow {
    color: #FFFFFF;
  }

  /* Dark theme + scrolled: revert to light text on navy pill */
  .header--dark.header--scrolled .header__nav-link {
    color: rgba(250, 250, 249, 0.7);
  }

  .header--dark.header--scrolled .header__nav-link:hover {
    color: #FAFAF9;
  }

  .header--dark.header--scrolled .header__nav-link::after {
    background: var(--stone-50);
  }

  .header--dark.header--scrolled .header__cta {
    color: #FFFFFF;
    border-bottom-color: #FFFFFF;
  }

  .header--dark.header--scrolled .header__cta:hover {
    color: rgba(250, 250, 249, 0.75);
  }

  .header--dark.header--scrolled .header__cta-arrow {
    color: #FFFFFF;
  }

  /* ============================================================
     HAMBURGER WRAPPER — hidden at desktop
  ============================================================ */
  .header__hamburger-wrap {
    display: none;
    align-items: center;
    position: relative;
    z-index: 10000;
    animation: hdrFadeDown 0.5s ease 0.38s both;
  }

  /* White hamburger lines (matches scrolled state) site-wide */
  .header__hamburger-wrap :global(path) {
    stroke: #ffffff;
    transition: stroke 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 768px) {
    .header__hamburger-wrap :global(path) {
      stroke: #ffffff;
    }
  }

  .header--scrolled .header__hamburger-wrap :global(path) {
    stroke: #ffffff;
  }

  /* ============================================================
     LOAD ANIMATION
  ============================================================ */
  @keyframes hdrFadeDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .header__logo,
    .header__nav-link,
    .header__cta,
    .header__hamburger-wrap {
      animation: none;
    }

    .header__cta-arrow {
      transition: none;
    }
  }

  /* Hide the bar hamburger once the menu is open — the in-menu one takes over.
     animation: none removes the hdrFadeDown fill (which holds opacity: 1)
     so that opacity: 0 can actually take effect. */
  .header--open .header__hamburger-wrap {
    animation: none;
    opacity: 0;
    pointer-events: none;
  }

  /* ============================================================
     FULL-SCREEN MOBILE MENU — closed state
  ============================================================ */
  .header__menu {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: radial-gradient(ellipse at 15% 60%, #243C60 0%, #1B3B49 65%);
    display: flex;
    flex-direction: column;
    padding: 100px 48px 52px;
    clip-path: inset(0 0 100% 0);
    /* Closing: snappy */
    transition: clip-path 0.45s cubic-bezier(0.76, 0, 0.24, 1);
    pointer-events: none;
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* Opening: slightly slower for drama */
  .header--open .header__menu {
    clip-path: inset(0 0 0% 0);
    pointer-events: auto;
    transition: clip-path 0.65s cubic-bezier(0.76, 0, 0.24, 1);
  }

  /* ============================================================
     IN-MENU LOGO (top-left)
  ============================================================ */
  .header__menu-logo {
    position: absolute;
    top: 28px;
    left: 48px;
    opacity: 0;
    transition: opacity 0.35s ease;
    text-decoration: none;
    display: block;
  }

  .header__menu-logo-img {
    height: 24px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .header--open .header__menu-logo {
    opacity: 1;
    transition-delay: 0.2s;
  }

  /* ============================================================
     IN-MENU HAMBURGER (close trigger)
  ============================================================ */
  .header__menu-hamburger {
    position: absolute;
    top: 16px;
    right: 20px;
    /* Fades in after menu wipe starts so it feels like a handoff */
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .header--open .header__menu-hamburger {
    opacity: 1;
    transition-delay: 0.2s;
  }

  /* ============================================================
     MENU NAV LINKS
  ============================================================ */
  .header__menu-nav {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
  }

  .header__menu-link {
    display: flex;
    align-items: baseline;
    gap: 16px;
    text-decoration: none;
    padding: 18px 0;
    border-bottom: 1px solid rgba(250, 250, 249, 0.08);
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      gap       0.3s  ease;
  }

  .header__menu-link:first-child {
    border-top: 1px solid rgba(250, 250, 249, 0.08);
  }

  .header__menu-link:hover {
    gap: 24px;
  }

  /* Staggered entry — uses nth-of-type so the sublinks <div> doesn't break the count */
  .header--open .header__menu-link:nth-of-type(1) { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }
  .header--open .header__menu-link:nth-of-type(2) { opacity: 1; transform: translateY(0); transition-delay: 0.35s; }
  .header--open .header__menu-link:nth-of-type(3) { opacity: 1; transform: translateY(0); transition-delay: 0.42s; }
  .header--open .header__menu-link:nth-of-type(4) { opacity: 1; transform: translateY(0); transition-delay: 0.49s; }
  .header--open .header__menu-link:nth-of-type(5) { opacity: 1; transform: translateY(0); transition-delay: 0.56s; }
  .header--open .header__menu-link:nth-of-type(6) { opacity: 1; transform: translateY(0); transition-delay: 0.63s; }

  /* ============================================================
     MENU SUB-LINKS — nested attorney pages under Our Team (mobile)
     The parent link drops its bottom border so the sublinks visually
     group with it as one Our Team block, divided from the next item
     by the sublinks container's own bottom border.
  ============================================================ */
  .header__menu-link--has-sub {
    border-bottom: none;
  }

  .header__menu-sublinks {
    display: flex;
    flex-direction: column;
    padding: 0 0 22px 44px;
    border-bottom: 1px solid rgba(250, 250, 249, 0.08);
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--open .header__menu-sublinks {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.46s;
  }

  .header__menu-sublink {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 6px 0;
    text-decoration: none;
    transition: gap 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__menu-sublink-dash {
    width: 22px;
    height: 1px;
    background: rgba(250, 250, 249, 0.4);
    flex-shrink: 0;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
  }

  .header__menu-sublink-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: rgba(250, 250, 249, 0.7);
    transition: color 0.3s ease;
  }

  .header__menu-sublink:hover {
    gap: 18px;
  }

  .header__menu-sublink:hover .header__menu-sublink-dash {
    width: 30px;
    background: #FAFAF9;
  }

  .header__menu-sublink:hover .header__menu-sublink-text {
    color: #FAFAF9;
  }

  .header__menu-num {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: rgba(250, 250, 249, 0.3);
    flex-shrink: 0;
    align-self: center;
    transition: color 0.3s ease;
  }

  .header__menu-text {
    font-family: 'Poppins', sans-serif;
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    color: rgba(250, 250, 249, 0.75);
    position: relative;
    transition: color 0.3s ease;
  }

  /* Underline grows left-to-right on hover */
  .header__menu-text::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: #FAFAF9;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__menu-link:hover .header__menu-num {
    color: rgba(250, 250, 249, 0.6);
  }

  .header__menu-link:hover .header__menu-text {
    color: #FAFAF9;
  }

  .header__menu-link:hover .header__menu-text::after {
    transform: scaleX(1);
  }

  /* ============================================================
     MENU FOOTER
  ============================================================ */
  .header__menu-footer {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-top: 32px;
    border-top: 1px solid rgba(250, 250, 249, 0.08);
    margin-top: 32px;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity   0.5s ease,
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--open .header__menu-footer {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.65s;
  }

  .header__menu-tagline {
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(250, 250, 249, 0.35);
    max-width: 180px;
  }

  .header__menu-cta {
    flex-shrink: 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding: 0 16px;
    border-bottom: 1px solid #FFFFFF;
    width: fit-content;
    background: none;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    white-space: nowrap;
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__menu-cta:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .header__menu-cta-arrow {
    width: 14px;
    height: 14px;
    color: #FFFFFF;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__menu-cta:hover .header__menu-cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ============================================================
     1024px — tighten desktop nav
  ============================================================ */
  @media (max-width: 1024px) {
    .header {
      padding: 24px 60px 0;
    }

    .header--scrolled {
      padding: 12px 32px;
    }

    .header__nav {
      gap: 20px;
    }

    .header__nav-link {
      font-size: 14px;
    }

    .header__cta {
      font-size: 13px;
    }
  }

  /* ============================================================
     768px — switch to hamburger
  ============================================================ */
  @media (max-width: 768px) {
    .header {
      padding: 16px 24px 0;
    }

    .header--scrolled {
      padding: 10px 16px;
    }

    .header__nav {
      display: none;
    }

    .header__cta {
      display: none;
    }

    .header__hamburger-wrap {
      display: flex;
      margin-left: auto;
    }

    .header__mobile-logo-link {
      display: block;
    }

    .header__menu {
      padding: 96px 40px 48px;
    }

    .header__menu-logo {
      left: 40px;
    }

    .header__menu-text {
      font-size: 32px;
    }
  }

  /* ============================================================
     480px
  ============================================================ */
  @media (max-width: 480px) {
    .header__menu {
      padding: 88px 28px 40px;
    }

    .header__menu-logo {
      left: 28px;
    }

    .header__menu-text {
      font-size: 26px;
    }

    .header__menu-link {
      padding: 14px 0;
    }

    .header__menu-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }

  /* ============================================================
     Reduced motion
  ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .header__menu {
      transition: none;
      clip-path: none;
      opacity: 0;
    }

    .header--open .header__menu {
      opacity: 1;
    }

    .header__menu-link,
    .header__menu-footer {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const headerEl      = document.querySelector('.header')       as HTMLElement     | null;
  const menuEl        = document.querySelector('.header__menu') as HTMLElement     | null;
  const checkbox      = document.getElementById('header-hamburger')       as HTMLInputElement | null;
  const closeCheckbox = document.getElementById('header-hamburger-close') as HTMLInputElement | null;

  function openMenu() {
    headerEl?.classList.add('header--open');
    menuEl?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    // Set the in-menu hamburger to the arrow/close state
    if (closeCheckbox) closeCheckbox.checked = true;
  }

  function closeMenu() {
    headerEl?.classList.remove('header--open');
    menuEl?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Reset both hamburgers back to three-lines state
    if (checkbox)      checkbox.checked      = false;
    if (closeCheckbox) closeCheckbox.checked = false;
  }

  // Bar hamburger drives open/close
  checkbox?.addEventListener('change', () => {
    checkbox.checked ? openMenu() : closeMenu();
  });

  // In-menu hamburger: clicking it unchecks → close
  closeCheckbox?.addEventListener('change', () => {
    if (!closeCheckbox.checked) closeMenu();
  });

  // Close on menu link click (includes nested attorney sublinks)
  menuEl?.querySelectorAll('.header__menu-link, .header__menu-sublink').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on desktop nav link click (same-page anchor) — includes dropdown items
  document.querySelectorAll('.header__nav-link, .header__dropdown-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && headerEl?.classList.contains('header--open')) {
      closeMenu();
    }
  });

  // ── Sticky pill on scroll ─────────────────────────────────
  function onScroll() {
    if (window.scrollY > 10) {
      headerEl?.classList.add('header--scrolled');
    } else {
      headerEl?.classList.remove('header--scrolled');
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
